<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TypeWhisper.Linux.ViewModels"
        xmlns:vms="using:TypeWhisper.Linux.ViewModels.Sections"
        xmlns:sections="using:TypeWhisper.Linux.Views.Sections"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="TypeWhisper.Linux.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="TypeWhisper"
        Width="1200" Height="780"
        RequestedThemeVariant="Dark">
    <Window.Resources>
        <DataTemplate x:Key="SectionTemplate_Dashboard" DataType="vms:DashboardSectionViewModel">
            <sections:DashboardSection />
        </DataTemplate>
    </Window.Resources>

    <Grid ColumnDefinitions="240,*" RowDefinitions="Auto,*">
        <!-- Header strip (spans both columns) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto" Margin="16,12">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppTitle}" FontSize="16" FontWeight="SemiBold" />
                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding VersionLabel}" FontSize="10"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Content="Open Wizard" Command="{Binding OpenWizardCommand}" />
            </StackPanel>
        </Grid>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderThickness="0,1,1,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <ScrollViewer>
                <ListBox ItemsSource="{Binding NavItems}"
                         SelectedItem="{Binding SelectedItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0,6">
                    <ListBox.Styles>
                        <!-- Headers render as non-selectable labels -->
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="CornerRadius" Value="0" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavItem">
                            <Grid>
                                <TextBlock Text="{Binding Label}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           IsVisible="{Binding IsHeader}"
                                           Margin="0,10,0,0" />
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            IsVisible="{Binding !IsHeader}">
                                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- Content area — bind CurrentSection to the right view via DataTemplates -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentSection}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vms:DashboardSectionViewModel">
                    <sections:DashboardSection />
                </DataTemplate>
                <DataTemplate DataType="vms:DictationSectionViewModel">
                    <sections:DictationSection />
                </DataTemplate>
                <DataTemplate DataType="vms:ShortcutsSectionViewModel">
                    <sections:ShortcutsSection />
                </DataTemplate>
                <DataTemplate DataType="vms:AudioSectionViewModel">
                    <sections:AudioSection />
                </DataTemplate>
                <DataTemplate DataType="vms:ModelsSectionViewModel">
                    <sections:ModelsSection />
                </DataTemplate>
                <DataTemplate DataType="vms:HistorySectionViewModel">
                    <sections:HistorySection />
                </DataTemplate>
                <DataTemplate DataType="vms:DictionarySectionViewModel">
                    <sections:DictionarySection />
                </DataTemplate>
                <DataTemplate DataType="vms:SnippetsSectionViewModel">
                    <sections:SnippetsSection />
                </DataTemplate>
                <DataTemplate DataType="vms:ProfilesSectionViewModel">
                    <sections:ProfilesSection />
                </DataTemplate>
                <DataTemplate DataType="vms:PromptsSectionViewModel">
                    <sections:PromptsSection />
                </DataTemplate>
                <DataTemplate DataType="vms:PluginsSectionViewModel">
                    <sections:PluginsSection />
                </DataTemplate>
                <DataTemplate DataType="vms:GeneralSectionViewModel">
                    <sections:GeneralSection />
                </DataTemplate>
                <DataTemplate DataType="vms:AboutSectionViewModel">
                    <sections:AboutSection />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
