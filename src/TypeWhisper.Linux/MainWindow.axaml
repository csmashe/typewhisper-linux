<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TypeWhisper.Linux.ViewModels"
        xmlns:local="using:TypeWhisper.Linux"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="TypeWhisper.Linux.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="TypeWhisper (Linux)"
        Width="900" Height="640">
    <DockPanel LastChildFill="True" Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="TypeWhisper Linux" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Shell scaffolding — views and transcription pipeline port incrementally from the Windows shell."
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="{Binding PluginsPath, StringFormat='Plugins: {0}'}"
                       FontFamily="monospace" FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <Border DockPanel.Dock="Top" Padding="12" Margin="0,0,0,12"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Toggle Recording" Command="{Binding ToggleRecordingCommand}" />
                    <Ellipse Width="14" Height="14" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding IsRecording, Converter={x:Static local:BoolColorConverter.Instance}}" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Global hotkey: Ctrl+Shift+Space (X11; Wayland depends on compositor)"
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="{Binding LastCapturePath, StringFormat='Last capture: {0}'}"
                           IsVisible="{Binding LastCapturePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           FontSize="11" FontFamily="monospace"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Load Plugins" Command="{Binding LoadPluginsCommand}" />
        </StackPanel>

        <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Plugins}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PluginItemViewModel">
                            <Border Padding="12,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Id}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Path}" FontSize="10" FontFamily="monospace"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Version, StringFormat='v{0}'}"
                                               VerticalAlignment="Center" Margin="12,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
