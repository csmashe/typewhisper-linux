<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:TypeWhisper.Core.Models"
        mc:Ignorable="d"
        x:Class="TypeWhisper.Linux.Views.PromptPaletteWindow"
        x:DataType="models:PromptAction"
        Title="Prompt Palette"
        Width="400"
        Height="400"
        MinWidth="400"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False">
    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
        <TextBox Grid.Row="0"
                 x:Name="SearchBox"
                 PlaceholderText="Search prompt actions"
                 TextChanged="SearchBox_OnTextChanged"
                 KeyDown="SearchBox_OnKeyDown" />

        <Border Grid.Row="0"
                x:Name="SourcePreviewBorder"
                Margin="0,44,0,6"
                Padding="10,6"
                CornerRadius="6"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                IsVisible="False">
            <TextBlock x:Name="SourcePreviewText"
                       TextWrapping="Wrap"
                       MaxHeight="36"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                CornerRadius="8"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1">
            <ListBox x:Name="ActionListBox"
                     SelectionChanged="ActionListBox_OnSelectionChanged"
                     DoubleTapped="ActionListBox_OnDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:PromptAction">
                        <Grid Margin="0,2" ColumnDefinitions="32,*">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Icon}"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock Grid.Row="1"
                   x:Name="EmptyText"
                   Text="No actions found"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   IsVisible="False" />

        <Border Grid.Row="2"
                x:Name="StatusBorder"
                Margin="0,8,0,0"
                Padding="10,6"
                CornerRadius="6"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                IsVisible="False">
            <TextBlock x:Name="StatusText"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>
    </Grid>
</Window>
