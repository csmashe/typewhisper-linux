<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:models="using:TypeWhisper.Core.Models"
             x:Class="TypeWhisper.Linux.Views.Sections.ProfilesSection"
             x:DataType="vm:ProfilesSectionViewModel">
    <Grid Margin="24" ColumnDefinitions="280,20,*">
        <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">
            <StackPanel Spacing="4" Margin="0,0,0,8">
                <TextBlock Text="Profiles" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Summary}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     BorderThickness="0"
                     Background="Transparent"
                     Margin="0,8,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Profile">
                        <Border Padding="12,10" Margin="0,0,0,8"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Priority, StringFormat='Priority {0}'}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                              Command="{Binding $parent[ListBox].((vm:ProfilesSectionViewModel)DataContext).ToggleProfileEnabledCommand}"
                                              CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2"
                    Content="New Profile"
                    Command="{Binding AddProfileCommand}"
                    Margin="0,12,0,0" />
        </Grid>

        <Border Grid.Column="2"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                CornerRadius="10"
                Padding="18">
            <ScrollViewer IsVisible="{Binding HasSelectedProfile}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SelectedProfileDisplayName}" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedProfileSummary}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                CornerRadius="999"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding MatchStatusText}" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource ControlFillColorTertiaryBrush}"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,16,0,0">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Current App" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CurrentProcessName}" />
                                    <TextBlock Text="{Binding CurrentWindowTitle}"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               IsVisible="{Binding HasCurrentWindowTitle}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Use current app"
                                        Command="{Binding AddCurrentProcessRuleCommand}"
                                        IsVisible="{Binding HasCurrentProcess}"
                                        VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Current Domain" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CurrentUrlPattern}"
                                               IsVisible="{Binding HasCurrentUrl}" />
                                    <TextBlock Text="No browser URL available"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               IsVisible="{Binding ShowNoBrowserUrlHint}" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Use current domain"
                                        Command="{Binding AddCurrentUrlRuleCommand}"
                                        IsVisible="{Binding HasCurrentUrl}"
                                        VerticalAlignment="Center" />
                            </Grid>

                            <Button Content="Open Live Context Window"
                                    HorizontalAlignment="Left"
                                    Command="{Binding OpenLiveContextWindowCommand}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2" Text="Name" Margin="0,16,0,6" />
                    <TextBox Grid.Row="3" Text="{Binding EditName}" />

                    <TextBlock Grid.Row="4" Text="Process Names" Margin="0,16,0,6" />
                    <ItemsControl Grid.Row="5" ItemsSource="{Binding ProcessNameChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding}" FontSize="11" />
                                        <Button Content="×"
                                                Padding="0"
                                                Width="18"
                                                Command="{Binding $parent[ItemsControl].((vm:ProfilesSectionViewModel)DataContext).RemoveProcessNameChipCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="6" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Text="{Binding ProcessNameInput}" PlaceholderText="Add process name" />
                        <Button Grid.Column="1" Content="Add" Command="{Binding AddProcessNameChipCommand}" />
                    </Grid>

                    <TextBlock Grid.Row="7" Text="URL Patterns" Margin="0,16,0,6" />
                    <ItemsControl Grid.Row="8" ItemsSource="{Binding UrlPatternChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        CornerRadius="12" Padding="8,4" Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding}" FontSize="11" />
                                        <Button Content="×"
                                                Padding="0"
                                                Width="18"
                                                Command="{Binding $parent[ItemsControl].((vm:ProfilesSectionViewModel)DataContext).RemoveUrlPatternChipCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="9" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Text="{Binding UrlPatternInput}" PlaceholderText="Add URL pattern" />
                        <Button Grid.Column="1" Content="Add" Command="{Binding AddUrlPatternChipCommand}" />
                    </Grid>

                    <Grid Grid.Row="10" ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Language" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding LanguageChoices}" SelectedItem="{Binding EditLanguage}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Task" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding TaskChoices}" SelectedItem="{Binding EditTask}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Priority" Margin="0,0,0,6" />
                            <NumericUpDown Minimum="-100" Maximum="100" Value="{Binding EditPriority}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="11" ColumnDefinitions="*,*,*,*" ColumnSpacing="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Transcription Model" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding ModelOptions}"
                                      SelectedValue="{Binding EditModelId}"
                                      SelectedValueBinding="{Binding Value}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProfileModelOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Prompt Action" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding PromptActionOptions}"
                                      SelectedValue="{Binding EditPromptActionId}"
                                      SelectedValueBinding="{Binding Value}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PromptActionOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Translation Target" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding TranslationTargetOptions}"
                                      SelectedItem="{Binding SelectedTranslationTargetOption}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:TranslationTargetOption">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Whisper Mode" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding WhisperModeOptions}"
                                      SelectedItem="{Binding SelectedWhisperModeOption}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NullableBooleanOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="12" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                        <CheckBox Content="Enabled" IsChecked="{Binding EditIsEnabled}" />
                    </StackPanel>

                    <StackPanel Grid.Row="13" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="Duplicate" Command="{Binding DuplicateProfileCommand}" />
                        <Button Content="Delete" Command="{Binding DeleteSelectedProfileCommand}" />
                        <Button Content="Save" Command="{Binding SaveProfileCommand}" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
