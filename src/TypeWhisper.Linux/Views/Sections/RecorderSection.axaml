<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             x:Class="TypeWhisper.Linux.Views.Sections.RecorderSection"
             x:DataType="vm:RecorderSectionViewModel">
    <UserControl.Styles>
        <Style Selector="Border.section-panel">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style Selector="Border.section-row">
            <Setter Property="Padding" Value="18,14" />
        </Style>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="TextBlock.page-subtitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#8A9AAE" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.section-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7D8796" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.row-title">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.row-hint">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#8A9AAE" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="860"
                    Margin="28"
                    Spacing="0">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Recorder"
                           Classes="page-title" />
                <TextBlock Text="Capture a longer take into a saved WAV file, then transcribe it automatically when recording stops."
                           Classes="page-subtitle" />
            </StackPanel>

            <TextBlock Text="Capture"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <StackPanel>
                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Recording session"
                                           Classes="row-title" />
                                <TextBlock Text="{Binding StatusText}"
                                           Classes="row-hint" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="{Binding RecordButtonText}"
                                    Command="{Binding ToggleRecordingCommand}"
                                    MinWidth="110"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="180,*"
                              ColumnSpacing="16">
                            <TextBlock Text="{Binding DurationText}"
                                       FontSize="42"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Input level"
                                           Classes="row-title" />
                                <ProgressBar Value="{Binding AudioLevel}"
                                             Maximum="1"
                                             Height="8"
                                             Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Saved recordings"
                       Classes="section-label" />
            <Border Classes="section-panel"
                    Margin="0">
                <ItemsControl ItemsSource="{Binding Recordings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RecordingItem">
                        <Border Classes="section-row"
                                Margin="0,0,0,12">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="16">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FileName}"
                                               Classes="row-title" />
                                    <TextBlock Text="{Binding Transcript}"
                                               Classes="row-hint"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="36"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                               FontSize="10"
                                               Foreground="#8A9AAE"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Button Content="Copy"
                                            Click="OnCopyTranscript"
                                            Tag="{Binding Transcript}"
                                            IsEnabled="{Binding Transcript, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                    <Button Content="Delete"
                                            Command="{Binding $parent[ItemsControl].((vm:RecorderSectionViewModel)DataContext).DeleteRecordingCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
