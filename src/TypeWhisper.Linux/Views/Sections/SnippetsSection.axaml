<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:models="using:TypeWhisper.Core.Models"
             x:Class="TypeWhisper.Linux.Views.Sections.SnippetsSection"
             x:DataType="vm:SnippetsSectionViewModel">
    <DockPanel Margin="16" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,12">
            <TextBlock Text="Snippets" FontSize="20" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Text expansion: saying a trigger phrase expands to replacement text (e.g. &quot;signoff&quot; → your full email signature)." />

            <Grid ColumnDefinitions="*,*,Auto,Auto" RowDefinitions="Auto">
                <TextBox Grid.Column="0" Text="{Binding NewTrigger}" PlaceholderText="Trigger phrase"
                         Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding NewReplacement}" PlaceholderText="Replacement text"
                         Margin="0,0,8,0" />
                <CheckBox Grid.Column="2" Content="Aa" IsChecked="{Binding CaseSensitive}"
                          ToolTip.Tip="Case-sensitive" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="Add" Command="{Binding AddSnippetCommand}" />
            </Grid>
        </StackPanel>

        <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Snippets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Snippet">
                            <Border Padding="12,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid ColumnDefinitions="*,2*,Auto,Auto,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Trigger}" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Replacement}"
                                               TextWrapping="Wrap" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding UsageCount, StringFormat='used {0}×'}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0" />
                                    <ToggleSwitch Grid.Column="3"
                                                  IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                  Command="{Binding $parent[ItemsControl].((vm:SnippetsSectionViewModel)DataContext).ToggleEnabledCommand}"
                                                  CommandParameter="{Binding}" />
                                    <Button Grid.Column="4" Content="Delete"
                                            Command="{Binding $parent[ItemsControl].((vm:SnippetsSectionViewModel)DataContext).DeleteCommand}"
                                            CommandParameter="{Binding}" Margin="8,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
