<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:models="using:TypeWhisper.Core.Models"
             x:Class="TypeWhisper.Linux.Views.Sections.SnippetsSection"
             x:DataType="vm:SnippetsSectionViewModel">
    <UserControl.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>
        <Style Selector="Border.badge">
            <Setter Property="Background" Value="#1B2430" />
            <Setter Property="BorderBrush" Value="#223243" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style Selector="Button.toolbar-button">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="28"
          RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Classes="panel"
                Padding="18,14"
                Margin="0,0,0,18">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <StackPanel Margin="0,0,18,0">
                    <TextBlock Text="Snippets"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="{Binding SummaryText}"
                               FontSize="12"
                               Foreground="#8A9AAE"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Placeholders: {date}, {time}, {datetime}, {day}, {year}, {clipboard}, {date:FORMAT}"
                               FontSize="11.5"
                               Foreground="#8A9AAE"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Double-click a row to edit it. Use tags to keep reusable phrases organized."
                               FontSize="11.5"
                               Foreground="#8A9AAE"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        Classes="toolbar-button"
                        Content="Import"
                        Click="OnImport" />
                <Button Grid.Column="2"
                        Classes="toolbar-button"
                        Content="Export"
                        Click="OnExport" />
                <Button Grid.Column="3"
                        Classes="toolbar-button"
                        Content="+ New"
                        Command="{Binding BeginCreateCommand}"
                        Background="#2196F3"
                        BorderBrush="#2196F3"
                        Foreground="White" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="panel"
                Padding="16,14"
                Margin="0,0,0,18"
                IsVisible="{Binding ShowEditor}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Row="0"
                           Text="{Binding EditorTitle}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="160,*,150"
                      ColumnSpacing="10">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewTrigger}"
                             PlaceholderText="Trigger" />
                    <TextBox Grid.Column="1"
                             Text="{Binding NewReplacement}"
                             PlaceholderText="Replacement text" />
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding TriggerModeOptions}"
                              SelectedValue="{Binding SelectedTriggerMode}"
                              SelectedValueBinding="{Binding Value}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SnippetTriggerModeOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*,Auto,Auto"
                      ColumnSpacing="10"
                      Margin="0,10,0,0">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewTags}"
                             PlaceholderText="Tags" />
                    <TextBox Grid.Column="1"
                             Text="{Binding NewProfileIds}"
                             PlaceholderText="Profile IDs" />
                    <CheckBox Grid.Column="2"
                              Content="Case sensitive"
                              IsChecked="{Binding CaseSensitive}"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                    <Button Content="{Binding EditorSaveText}"
                            Command="{Binding SaveSnippetCommand}"
                            Background="#2196F3"
                            BorderBrush="#2196F3"
                            Foreground="White"
                            MinWidth="118"
                            Padding="14,8" />
                    <Button Content="Cancel"
                            Command="{Binding CancelEditCommand}"
                            MinWidth="82"
                            Padding="14,8" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="3"
                        Background="#101820"
                        BorderBrush="#223243"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,12,0,0"
                        IsVisible="{Binding ShowPreview}">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Preview"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#8A9AAE" />
                        <TextBlock Text="{Binding PreviewText}"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"
                                   Foreground="#D8E6F7" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Background="#241D12"
                        BorderBrush="#6A4A1D"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,10,0,0"
                        IsVisible="{Binding HasConflictWarning}">
                    <TextBlock Text="{Binding ConflictWarningText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="#F4C97D" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Classes="panel">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                          ColumnSpacing="10">
                        <TextBlock Grid.Column="0"
                                   Text="Tag filter:"
                                   FontSize="12"
                                   Foreground="#8A9AAE"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Width="180"
                                  ItemsSource="{Binding AvailableTags}"
                                  SelectedItem="{Binding SelectedTagFilter}" />
                        <Button Grid.Column="2"
                                Content="All tags"
                                Command="{Binding ClearTagFilterCommand}"
                                IsVisible="{Binding HasSelectedTagFilter}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="420"
                                IsVisible="{Binding ShowEmptyState}">
                        <TextBlock Text="♪"
                                   FontSize="38"
                                   Foreground="#8A9AAE"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="No snippets yet."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Create short triggers that expand into longer text automatically after transcription."
                                   FontSize="12.5"
                                   Foreground="#8A9AAE"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,18" />
                        <Button Content="+ Create first snippet"
                                Command="{Binding BeginCreateCommand}"
                                HorizontalAlignment="Center"
                                Padding="16,8"
                                Background="#2196F3"
                                BorderBrush="#2196F3"
                                Foreground="White" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding ShowSnippetList}">
                        <ItemsControl ItemsSource="{Binding FilteredSnippets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Snippet">
                                    <Border Padding="16,13"
                                            BorderBrush="#1AFFFFFF"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto"
                                              ColumnSpacing="14">
                                            <Border Grid.Column="0"
                                                    Background="#14337FD8"
                                                    BorderBrush="#225E9FF2"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="9,4"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Trigger}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#8FC0FF" />
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       Text="->"
                                                       FontSize="12"
                                                       Foreground="#8A9AAE"
                                                       Margin="0,4,0,0" />

                                            <StackPanel Grid.Column="2"
                                                        Margin="0,0,14,0">
                                                <TextBlock Text="{Binding Replacement}"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis" />
                                                <WrapPanel Margin="0,7,0,0">
                                                    <Border Classes="badge"
                                                            IsVisible="{Binding CaseSensitive}">
                                                        <TextBlock Text="Aa"
                                                                   FontSize="10"
                                                                   Foreground="#D6DEE9" />
                                                    </Border>
                                                    <Border Classes="badge">
                                                        <TextBlock Text="{Binding TriggerMode}"
                                                                   FontSize="10"
                                                                   Foreground="#D6DEE9" />
                                                    </Border>
                                                    <Border Classes="badge">
                                                        <TextBlock Text="{Binding UsageCount, StringFormat='{}{0}x'}"
                                                                   FontSize="10"
                                                                   Foreground="#D6DEE9" />
                                                    </Border>
                                                    <Border Classes="badge"
                                                            IsVisible="{Binding Tags, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock Text="{Binding Tags}"
                                                                   FontSize="10"
                                                                   Foreground="#D6DEE9" />
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>

                                            <Button Grid.Column="3"
                                                    Content="Edit"
                                                    Command="{Binding $parent[ItemsControl].((vm:SnippetsSectionViewModel)DataContext).BeginEditCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="12,6"
                                                    VerticalAlignment="Center" />
                                            <Button Grid.Column="4"
                                                    Content="Delete"
                                                    Command="{Binding $parent[ItemsControl].((vm:SnippetsSectionViewModel)DataContext).DeleteCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="12,6"
                                                    VerticalAlignment="Center" />
                                            <ToggleSwitch Grid.Column="5"
                                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                          Command="{Binding $parent[ItemsControl].((vm:SnippetsSectionViewModel)DataContext).ToggleEnabledCommand}"
                                                          CommandParameter="{Binding}"
                                                          VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
