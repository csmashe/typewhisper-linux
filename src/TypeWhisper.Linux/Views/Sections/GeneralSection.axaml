<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             x:Class="TypeWhisper.Linux.Views.Sections.GeneralSection"
             x:DataType="vm:GeneralSectionViewModel">
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="General" FontSize="20" FontWeight="SemiBold" />

            <CheckBox Content="Auto-paste transcription into focused window"
                      IsChecked="{Binding AutoPaste}" />
            <CheckBox Content="Save transcriptions to history"
                      IsChecked="{Binding SaveToHistoryEnabled}" />
            <CheckBox Content="Play sound when recording starts/stops"
                      IsChecked="{Binding SoundFeedbackEnabled}" />

            <StackPanel Spacing="6">
                <TextBlock Text="History retention" FontWeight="SemiBold" />
                <TextBlock Text="Controls how long transcription history and saved WAV files are kept on disk."
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding HistoryRetentionOptions}"
                          SelectedItem="{Binding SelectedHistoryRetention}"
                          Width="220"
                          HorizontalAlignment="Left">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:HistoryRetentionOption">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Dictation language hint" FontWeight="SemiBold" />
                <TextBlock Text="'auto' detects from speech; pin one for better accuracy if you always speak the same language."
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ComboBox ItemsSource="{Binding LanguageChoices}"
                          SelectedItem="{Binding Language}"
                          Width="200" HorizontalAlignment="Left" />
            </StackPanel>

            <Separator Margin="0,8,0,0" />
            <TextBlock Text="Window behavior" FontWeight="SemiBold" />
            <CheckBox Content="Close button minimizes to tray instead of quitting"
                      IsChecked="{Binding CloseToTray}" />
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Off: the X button fully quits the app (default; safe on desktops without a system tray). On: the X button hides the window and the tray icon stays — use the tray menu's Exit to actually quit." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
