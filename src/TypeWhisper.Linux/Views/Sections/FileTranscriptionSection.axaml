<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:svc="using:TypeWhisper.Linux.Services"
             x:Class="TypeWhisper.Linux.Views.Sections.FileTranscriptionSection"
             x:DataType="vm:FileTranscriptionSectionViewModel">
    <UserControl.Styles>
        <Style Selector="Border.section-panel">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style Selector="Border.section-row">
            <Setter Property="Padding" Value="18,14" />
        </Style>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="TextBlock.page-subtitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#8A9AAE" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.section-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7D8796" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.row-title">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.row-hint">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#8A9AAE" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style Selector="Border.drop-zone">
            <Setter Property="Background" Value="#111822" />
            <Setter Property="BorderBrush" Value="#2B3B4B" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>
        <Style Selector="Border.drop-zone.drag-over">
            <Setter Property="Background" Value="#162539" />
            <Setter Property="BorderBrush" Value="#2E8FFF" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28"
                    MaxWidth="860">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="File transcription"
                           Classes="page-title" />
                <TextBlock Text="Transcribe existing recordings or media files without using the microphone. Audio and video inputs are converted locally before transcription."
                           Classes="page-subtitle" />
            </StackPanel>

            <TextBlock Text="Import"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <StackPanel>
                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Choose source files"
                                           Classes="row-title" />
                                <TextBlock Text="Drop supported audio or video files here, or browse manually. Supported formats include WAV, MP3, M4A, FLAC, MP4, MOV, MKV, AVI, and WEBM."
                                           Classes="row-hint" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Select files..."
                                    Click="OnSelectFile"
                                    IsEnabled="{Binding CanImportFiles}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Border x:Name="DropZone"
                                Classes="drop-zone"
                                Padding="26"
                                IsEnabled="{Binding CanImportFiles}">
                            <StackPanel HorizontalAlignment="Center"
                                        Spacing="8">
                                <TextBlock Text="Drag audio/video files here"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="The file is converted to a mono 16 kHz WAV stream before transcription."
                                           Classes="row-hint"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           MaxWidth="460" />
                                <TextBlock Text="{Binding ImporterUnavailableReason}"
                                           FontSize="12"
                                           Foreground="#AFC0D3"
                                           IsVisible="{Binding ShowImporterUnavailableReason}"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Importer status"
                                           Classes="row-title" />
                                <TextBlock Text="{Binding StatusText}"
                                           Classes="row-hint" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="Cancel"
                                    Command="{Binding CancelCommand}"
                                    IsVisible="{Binding IsProcessing}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0"
                            IsVisible="{Binding IsProcessing}" />

                    <Border Classes="section-row"
                            IsVisible="{Binding IsProcessing}">
                        <ProgressBar IsIndeterminate="{Binding IsProcessing}"
                                     Height="6" />
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Queue"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <StackPanel>
                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel>
                                <TextBlock Text="Batch transcription"
                                           Classes="row-title" />
                                <TextBlock Text="{Binding StatusText}"
                                           Classes="row-hint" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Cancel all"
                                    Command="{Binding CancelCommand}"
                                    IsVisible="{Binding IsProcessing}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <ListBox ItemsSource="{Binding Items}"
                                 SelectedItem="{Binding SelectedItem}"
                                 MinHeight="120"
                                 MaxHeight="260"
                                 Background="#111822"
                                 BorderBrush="#243244"
                                 BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:FileTranscriptionQueueItemViewModel">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="12"
                                          Margin="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="12"
                                                       Foreground="#8A9AAE"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    VerticalAlignment="Center">
                                            <Button Content="Copy"
                                                    Click="OnCopyItem"
                                                    IsVisible="{Binding HasResult}" />
                                            <Button Content="TXT"
                                                    Click="OnExportItemText"
                                                    IsVisible="{Binding HasResult}" />
                                            <Button Content="SRT"
                                                    Click="OnExportItemSrt"
                                                    IsVisible="{Binding CanExportSubtitles}" />
                                            <Button Content="VTT"
                                                    Click="OnExportItemVtt"
                                                    IsVisible="{Binding CanExportSubtitles}" />
                                            <Button Content="Cancel"
                                                    Command="{Binding $parent[UserControl].DataContext.CancelItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding CanCancel}" />
                                            <Button Content="Remove"
                                                    Command="{Binding $parent[UserControl].DataContext.RemoveItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding !IsProcessing}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Transcript"
                       Classes="section-label" />
            <Border Classes="section-panel"
                    Margin="0">
                <StackPanel>
                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Result"
                                           Classes="row-title" />
                                <TextBlock Classes="row-hint">
                                    <Run Text="Detected language: " />
                                    <Run Text="{Binding DetectedLanguage}" />
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding HasResult}">
                                <Button Content="Copy"
                                        Click="OnCopy" />
                                <Button Content="TXT"
                                        Click="OnExportText" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <TextBox Text="{Binding ResultText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="260"
                                 Background="#111822"
                                 BorderBrush="#243244"
                                 BorderThickness="1" />
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Watch folder"
                       Classes="section-label" />
            <Border Classes="section-panel"
                    Margin="0">
                <StackPanel>
                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel>
                                <TextBlock Text="Automation"
                                           Classes="row-title" />
                                <TextBlock Text="{Binding WatchFolderStatusText}"
                                           Classes="row-hint" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Start"
                                        Command="{Binding StartWatchFolderCommand}"
                                        IsEnabled="{Binding IsWatchFolderStopped}" />
                                <Button Content="Stop"
                                        Command="{Binding StopWatchFolderCommand}"
                                        IsEnabled="{Binding IsWatchFolderRunning}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12"
                              RowSpacing="10">
                            <TextBox Grid.Column="0"
                                     Text="{Binding WatchFolderPath}"
                                     PlaceholderText="Folder to watch" />
                            <Button Grid.Column="1"
                                    Content="Choose..."
                                    Click="OnSelectWatchFolder" />

                            <TextBox Grid.Row="1"
                                     Grid.Column="0"
                                     Text="{Binding WatchFolderOutputPath}"
                                     PlaceholderText="Output folder (optional)" />
                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Choose..."
                                        Click="OnSelectWatchFolderOutput" />
                                <Button Content="Clear"
                                        Command="{Binding ClearWatchFolderOutputPathCommand}" />
                            </StackPanel>

                            <TextBox Grid.Row="2"
                                     Grid.Column="0"
                                     Text="{Binding WatchFolderOutputFormat}"
                                     PlaceholderText="Output format: md, txt, srt, vtt" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Text="{Binding WatchFolderLanguage}"
                                     PlaceholderText="Language" />

                            <CheckBox Grid.Row="3"
                                      Grid.ColumnSpan="2"
                                      Content="Start watching automatically when TypeWhisper opens"
                                      IsChecked="{Binding WatchFolderAutoStart}" />
                            <CheckBox Grid.Row="4"
                                      Grid.ColumnSpan="2"
                                      Content="Delete source files after successful transcription"
                                      IsChecked="{Binding WatchFolderDeleteSource}" />
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="History"
                                           Classes="row-title" />
                                <Button Grid.Column="1"
                                        Content="Clear"
                                        Command="{Binding ClearWatchFolderHistoryCommand}"
                                        IsEnabled="{Binding HasWatchFolderHistory}" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding WatchFolderHistory}"
                                          Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="svc:WatchFolderHistoryItem">
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding OutputPath}"
                                                       FontSize="12"
                                                       Foreground="#8A9AAE"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding ErrorMessage}"
                                                       FontSize="12"
                                                       Foreground="#FF8A8A"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding !Success}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
