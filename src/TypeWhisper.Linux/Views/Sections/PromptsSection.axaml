<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:models="using:TypeWhisper.Core.Models"
             x:Class="TypeWhisper.Linux.Views.Sections.PromptsSection"
             x:DataType="vm:PromptsSectionViewModel">
    <Grid Margin="24" RowDefinitions="Auto,*">
        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,16">
            <Grid ColumnDefinitions="*,320,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Prompt Actions" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Summary}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Default provider" />
                    <ComboBox ItemsSource="{Binding AvailableProviders}"
                              SelectedValue="{Binding DefaultLlmProvider}"
                              SelectedValueBinding="{Binding Value}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProviderOption">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Seed Presets" Command="{Binding SeedPresetsCommand}" />
                    <Button Content="New Prompt" Command="{Binding StartCreateCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="320,20,*">
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Actions}"
                     SelectedItem="{Binding SelectedAction}"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:PromptAction">
                        <Border Padding="12,10" Margin="0,0,0,8"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="8">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Text="{Binding Icon}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SystemPrompt}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               MaxLines="2"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="2"
                                              IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                              Command="{Binding $parent[ListBox].((vm:PromptsSectionViewModel)DataContext).ToggleEnabledCommand}"
                                              CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    CornerRadius="10"
                    Padding="18">
                <Grid IsVisible="{Binding HasSelectedAction}"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">
                    <TextBlock Text="{Binding SelectedAction.Name}" FontSize="20" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="1" Text="Name" Margin="0,16,0,6" />
                    <TextBox Grid.Row="2" Text="{Binding EditName}" />

                    <TextBlock Grid.Row="3" Text="System Prompt" Margin="0,16,0,6" />
                    <TextBox Grid.Row="4"
                             Text="{Binding EditSystemPrompt}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="120" />

                    <Grid Grid.Row="5" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Provider" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding AvailableProviders}"
                                      SelectedValue="{Binding EditProviderOverride}"
                                      SelectedValueBinding="{Binding Value}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ProviderOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Action Plugin" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding ActionPluginOptions}"
                                      SelectedValue="{Binding EditTargetActionPluginId}"
                                      SelectedValueBinding="{Binding Value}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ActionPluginOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="Up"
                                Command="{Binding MoveUpCommand}"
                                CommandParameter="{Binding SelectedAction}" />
                        <Button Content="Down"
                                Command="{Binding MoveDownCommand}"
                                CommandParameter="{Binding SelectedAction}" />
                        <Button Content="Delete"
                                Command="{Binding DeleteSelectedActionCommand}" />
                        <Button Content="Save"
                                Command="{Binding SaveActionCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
