<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             x:Class="TypeWhisper.Linux.Views.Sections.PluginsSection"
             x:DataType="vm:PluginsSectionViewModel">
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="14">
            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Extensions"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Plugins extend TypeWhisper with additional transcription engines, LLM providers, and post-processing."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,12">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <TextBlock Text="Installed"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,10">
                        <TextBlock Text="{Binding HeaderSummary}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>

                    <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14,12"
                            IsVisible="{Binding HasLoadFailures}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Plugin load failures"
                                       FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{Binding LoadFailures}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PluginFailureRow">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding FolderName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding PluginGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PluginCategoryGroup">
                                <StackPanel Spacing="10" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />

                                    <ItemsControl ItemsSource="{Binding Plugins}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PluginRow">
                                                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="14,12"
                                                        Margin="0,0,0,10">
                                                    <StackPanel Spacing="12">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                              ColumnSpacing="12">
                                                            <Border Width="40"
                                                                    Height="40"
                                                                    CornerRadius="10"
                                                                    Background="#1E88E5"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding Monogram}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="White"
                                                                           FontWeight="Bold" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1" Spacing="5">
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}"
                                                                           TextWrapping="Wrap"
                                                                           IsVisible="{Binding HasDescription}"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <Border Background="#1A3453"
                                                                            BorderBrush="#2E5B89"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding CategoryLabel}"
                                                                                   FontSize="11"
                                                                                   Foreground="#D6E7FF" />
                                                                    </Border>
                                                                    <Border Background="{Binding LocationBadgeBackground}"
                                                                            BorderBrush="{Binding LocationBadgeBorder}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding LocationBadge}"
                                                                                   FontSize="11"
                                                                                   Foreground="{Binding LocationBadgeForeground}" />
                                                                    </Border>
                                                                    <Border Background="{Binding StatusBadgeBackground}"
                                                                            BorderBrush="{Binding StatusBadgeBorder}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="999"
                                                                            Padding="8,3">
                                                                        <TextBlock Text="{Binding StatusBadge}"
                                                                                   FontSize="11"
                                                                                   Foreground="{Binding StatusBadgeForeground}" />
                                                                    </Border>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <ToggleSwitch Grid.Column="2"
                                                                          Margin="0,0,4,0"
                                                                          VerticalAlignment="Center"
                                                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                          Command="{Binding Owner.ToggleEnabledCommand}"
                                                                          CommandParameter="{Binding}" />

                                                            <Button Grid.Column="3"
                                                                    Width="34"
                                                                    Height="34"
                                                                    Padding="0"
                                                                    VerticalAlignment="Center"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Command="{Binding Owner.ToggleExpandedCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    IsVisible="{Binding HasExpandableSettings}">
                                                                <TextBlock Text="{Binding ExpansionGlyph}"
                                                                           FontSize="16"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                            </Button>
                                                        </Grid>

                                                        <Border IsVisible="{Binding IsExpanded}"
                                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                BorderThickness="1,1,1,0"
                                                                CornerRadius="8"
                                                                Padding="14,14,14,0">
                                                            <StackPanel Spacing="14">
                                                                <TextBlock Text="{Binding Status}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                                                                <ItemsControl ItemsSource="{Binding SettingFields}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:PluginSettingFieldRow">
                                                                            <StackPanel Spacing="6" Margin="0,0,0,14">
                                                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />

                                                                                <TextBlock Text="{Binding Description}"
                                                                                           FontSize="11"
                                                                                           TextWrapping="Wrap"
                                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                           IsVisible="{Binding HasDescription}" />

                                                                                <ComboBox ItemsSource="{Binding Options}"
                                                                                          SelectedItem="{Binding SelectedOption}"
                                                                                          HorizontalAlignment="Stretch"
                                                                                          IsVisible="{Binding HasOptions}">
                                                                                    <ComboBox.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <TextBlock Text="{Binding Label}" />
                                                                                        </DataTemplate>
                                                                                    </ComboBox.ItemTemplate>
                                                                                </ComboBox>

                                                                                <TextBox Text="{Binding Value}"
                                                                                         PlaceholderText="{Binding Placeholder}"
                                                                                         HorizontalAlignment="Stretch"
                                                                                         IsVisible="{Binding !HasOptions}" />
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <StackPanel Orientation="Horizontal"
                                                                            HorizontalAlignment="Right"
                                                                            Spacing="8"
                                                                            Margin="0,0,0,14">
                                                                    <Button Content="Save"
                                                                            Command="{Binding Owner.SaveSettingsCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            IsEnabled="{Binding CanEditSettings}" />
                                                                    <Button Content="Validate"
                                                                            Command="{Binding Owner.ValidateSettingsCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            IsEnabled="{Binding CanValidateSettings}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
