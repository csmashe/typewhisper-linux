<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:models="using:TypeWhisper.Core.Models"
             xmlns:local="using:TypeWhisper.Linux"
             x:Class="TypeWhisper.Linux.Views.Sections.DictionarySection"
             x:DataType="vm:DictionarySectionViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>
        <Style Selector="Border.tab-button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style Selector="Border.entry-card">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="16,13" />
        </Style>
        <Style Selector="Border.pack-card">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Width" Value="252" />
            <Setter Property="MinHeight" Value="104" />
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="28">
        <StackPanel MaxWidth="980">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="10"
                  Margin="0,0,0,14">
                <TextBlock Text="Dictionary"
                           Classes="page-title"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Import"
                        Click="OnImport"
                        Padding="12,7" />
                <Button Grid.Column="2"
                        Content="Export"
                        Click="OnExport"
                        Padding="12,7" />
            </Grid>

            <Border Classes="panel"
                    Padding="14,12"
                    Margin="0,0,0,12">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="16">
                    <StackPanel>
                        <TextBlock Text="Enable vocabulary boosting"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Improves recognition of active dictionary terms and packs for local transcriptions"
                                   FontSize="12"
                                   Foreground="#8A9AAE"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding VocabularyBoostingStatusText}"
                                   FontSize="12"
                                   Foreground="#8A9AAE"
                                   Margin="0,8,0,0" />
                    </StackPanel>

                    <ToggleSwitch Grid.Column="1"
                                  IsChecked="{Binding VocabularyBoostingEnabled}"
                                  VerticalAlignment="Top" />
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">
                <Button Command="{Binding SetTabCommand}"
                        CommandParameter="0"
                        Background="{Binding IsAllTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        BorderBrush="{Binding IsAllTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        Foreground="{Binding IsAllTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#FFFFFF|False=#D6DEE9'}"
                        Padding="12,8"
                        Margin="0,0,8,0"
                        Content="All" />
                <Button Command="{Binding SetTabCommand}"
                        CommandParameter="1"
                        Background="{Binding IsTermsTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        BorderBrush="{Binding IsTermsTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        Foreground="{Binding IsTermsTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#FFFFFF|False=#D6DEE9'}"
                        Padding="12,8"
                        Margin="0,0,8,0"
                        Content="Terms" />
                <Button Command="{Binding SetTabCommand}"
                        CommandParameter="2"
                        Background="{Binding IsCorrectionsTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        BorderBrush="{Binding IsCorrectionsTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        Foreground="{Binding IsCorrectionsTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#FFFFFF|False=#D6DEE9'}"
                        Padding="12,8"
                        Margin="0,0,8,0"
                        Content="Corrections" />
                <Button Command="{Binding SetTabCommand}"
                        CommandParameter="3"
                        Background="{Binding IsPacksTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        BorderBrush="{Binding IsPacksTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#2196F3|False=Transparent'}"
                        Foreground="{Binding IsPacksTabSelected, Converter={x:Static local:BoolBrushConverter.Instance}, ConverterParameter='True=#FFFFFF|False=#D6DEE9'}"
                        Padding="12,8"
                        Content="Packs" />
            </StackPanel>

            <Border Classes="panel"
                    Padding="12"
                    Margin="0,0,0,12"
                    IsVisible="{Binding ShowFilterRow}">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText}"
                             PlaceholderText="Search entries..."
                             IsVisible="{Binding ShowSearchBox}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding EntryCount, StringFormat='{}{0} Entries'}"
                               VerticalAlignment="Center"
                               Foreground="#8A9AAE"
                               FontSize="12" />
                </Grid>
            </Border>

            <TextBlock Text="Packs add specialized terminology so speech recognition better understands domain vocabulary."
                       FontSize="12.5"
                       Foreground="#8A9AAE"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       IsVisible="{Binding ShowPacksHeader}" />

            <Border Classes="panel"
                    Height="300"
                    Margin="0,0,0,12">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsVisible="{Binding ShowEmptyState}">
                        <TextBlock Text="▣"
                                   FontSize="38"
                                   Foreground="#566273"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding EmptyStateTitle}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="{Binding EmptyStateSubtitle}"
                                   FontSize="12"
                                   Foreground="#8A9AAE"
                                   HorizontalAlignment="Center"
                                    Margin="0,6,0,0" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding ShowEntriesList}">
                        <ItemsControl ItemsSource="{Binding FilteredEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DictionaryEntry">
                                    <Border Classes="entry-card">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                                              ColumnSpacing="14">
                                            <StackPanel Grid.Column="0"
                                                        MinWidth="180">
                                                <TextBlock Text="{Binding Original}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Replacement}"
                                                           FontSize="12"
                                                           Foreground="#8A9AAE"
                                                           Margin="0,4,0,0"
                                                           IsVisible="{Binding Replacement, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Border Background="#1B2430"
                                                        BorderBrush="#223243"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="8,3">
                                                    <TextBlock Text="{Binding EntryType}"
                                                               FontSize="10.5"
                                                               Foreground="#D6DEE9" />
                                                </Border>
                                                <Border Background="#1B2430"
                                                        BorderBrush="#223243"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="8,3"
                                                        IsVisible="{Binding CaseSensitive}">
                                                    <TextBlock Text="Aa"
                                                               FontSize="10.5"
                                                               Foreground="#D6DEE9" />
                                                </Border>
                                                <Border Background="#1B2430"
                                                        BorderBrush="#223243"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="8,3">
                                                    <TextBlock Text="{Binding UsageCount, StringFormat='{}{0}x'}"
                                                               FontSize="10.5"
                                                               Foreground="#D6DEE9" />
                                                </Border>
                                                <Border Background="#1B2430"
                                                        BorderBrush="#223243"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="8,3">
                                                    <TextBlock Text="{Binding Priority, StringFormat='Priority {0}'}"
                                                               FontSize="10.5"
                                                               Foreground="#D6DEE9" />
                                                </Border>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="{Binding IsStarred, Converter={x:Static local:BoolTextConverter.Instance}, ConverterParameter='True=★|False=☆'}"
                                                    Command="{Binding $parent[ItemsControl].((vm:DictionarySectionViewModel)DataContext).ToggleStarredCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,6"
                                                    MinWidth="38"
                                                    VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <Button Content="−"
                                                        Command="{Binding $parent[ItemsControl].((vm:DictionarySectionViewModel)DataContext).DecreasePriorityCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,6"
                                                        MinWidth="30" />
                                                <Button Content="+"
                                                        Command="{Binding $parent[ItemsControl].((vm:DictionarySectionViewModel)DataContext).IncreasePriorityCommand}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,6"
                                                        MinWidth="30" />
                                            </StackPanel>

                                            <ToggleSwitch Grid.Column="4"
                                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                          Command="{Binding $parent[ItemsControl].((vm:DictionarySectionViewModel)DataContext).ToggleEnabledCommand}"
                                                          CommandParameter="{Binding}"
                                                          VerticalAlignment="Center" />

                                            <Button Grid.Column="5"
                                                    Content="Delete"
                                                    Command="{Binding $parent[ItemsControl].((vm:DictionarySectionViewModel)DataContext).DeleteCommand}"
                                                    CommandParameter="{Binding}"
                                                    Padding="12,6"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding ShowPacksList}">
                        <ItemsControl ItemsSource="{Binding Packs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TermPackItemViewModel">
                                    <Border Classes="pack-card">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="14">
                                            <StackPanel>
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2">
                                                    <Run Text="{Binding Pack.Icon}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding Pack.Name}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding TermCountLabel}"
                                                           FontSize="11"
                                                           Foreground="#8A9AAE"
                                                           Margin="0,2,0,0" />
                                                <TextBlock Text="{Binding TermsPreview}"
                                                           FontSize="12"
                                                           Foreground="#8A9AAE"
                                                           MaxLines="2"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>

                                            <ToggleSwitch Grid.Column="1"
                                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                          Command="{Binding $parent[ItemsControl].((vm:DictionarySectionViewModel)DataContext).TogglePackCommand}"
                                                          CommandParameter="{Binding}"
                                                          VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Classes="panel"
                    Padding="14,12"
                    IsVisible="{Binding ShowAddBar}">
                <Grid ColumnDefinitions="*,Auto,*,92,Auto,Auto,Auto,Auto"
                      ColumnSpacing="10">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewOriginal}"
                             PlaceholderText="Enter original..." />
                    <TextBlock Grid.Column="1"
                               Text="→"
                               VerticalAlignment="Center"
                               Foreground="#8A9AAE" />
                    <TextBox Grid.Column="2"
                             Text="{Binding NewReplacement}"
                             PlaceholderText="Replacement (optional)" />
                    <NumericUpDown Grid.Column="3"
                                   Minimum="0"
                                   Maximum="999"
                                   Value="{Binding NewPriority}"
                                   PlaceholderText="Priority" />
                    <ToggleButton Grid.Column="4"
                                  IsChecked="{Binding IsNewTypeCorrection}"
                                  Content="Correction"
                                  Padding="10,6" />
                    <ToggleButton Grid.Column="5"
                                  IsChecked="{Binding IsNewTypeTerm}"
                                  Content="Term"
                                  Padding="10,6" />
                    <CheckBox Grid.Column="6"
                              Content="Aa"
                              IsChecked="{Binding CaseSensitive}"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="7"
                            Content="+ Add"
                            Command="{Binding AddEntryCommand}"
                            Padding="14,7" />
                </Grid>
            </Border>
        </StackPanel>
    </DockPanel>
</UserControl>
