<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:svc="using:TypeWhisper.Linux.Services"
             xmlns:models="using:TypeWhisper.Core.Models"
             x:Class="TypeWhisper.Linux.Views.Sections.AudioSection"
             x:DataType="vm:AudioSectionViewModel">
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="Audio input" FontSize="20" FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Microphone" VerticalAlignment="Center" Width="120" />
                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          Width="360">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="svc:AudioInputDevice">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Text="(default)" FontStyle="Italic"
                                           IsVisible="{Binding IsDefault}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Refresh" Command="{Binding RefreshDevicesCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Input preview" FontWeight="SemiBold" />
                    <ProgressBar Minimum="0" Maximum="1" Value="{Binding PreviewLevel}" Height="14" Width="360" />
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding IsPreviewActive, StringFormat='Live level preview active: {0}'}" />
                </StackPanel>
            </Border>

            <Separator Margin="0,12,0,0" />
            <TextBlock Text="Audio routing" FontWeight="SemiBold" />
            <CheckBox Content="Duck other audio while recording"
                      IsChecked="{Binding AudioDuckingEnabled}"
                      ToolTip.Tip="Lower the volume of other apps while you dictate. Uses pactl on Linux." />
            <CheckBox Content="Pause media playback during recording"
                      IsChecked="{Binding PauseMediaDuringRecording}"
                      ToolTip.Tip="Pause supported MPRIS/media players while recording. Uses playerctl on Linux." />
            <TextBlock Text="These features are best-effort and depend on Linux desktop tools being available: pactl for ducking and playerctl for media control."
                       FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" />

            <Separator Margin="0,12,0,0" />
            <StackPanel Spacing="8">
                <TextBlock Text="Translation" FontWeight="SemiBold" />
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Optional post-processing step that translates dictation output after transcription and prompt actions. Uses an available LLM provider first, then falls back to local ONNX models when needed." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Target language" VerticalAlignment="Center" Width="120" />
                    <ComboBox ItemsSource="{Binding TranslationTargetOptions}"
                              SelectedItem="{Binding SelectedTranslationTargetOption}"
                              Width="240">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:TranslationTargetOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
