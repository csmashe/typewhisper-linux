<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             xmlns:models="using:TypeWhisper.Core.Models"
             xmlns:local="using:TypeWhisper.Linux"
             x:Class="TypeWhisper.Linux.Views.Sections.ShortcutsSection"
             x:DataType="vm:ShortcutsSectionViewModel">
    <UserControl.Styles>
        <Style Selector="Border.section-panel">
            <Setter Property="Background" Value="#141D26" />
            <Setter Property="BorderBrush" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
        <Style Selector="Border.section-row">
            <Setter Property="Padding" Value="18,14" />
        </Style>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="TextBlock.page-subtitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#8A9AAE" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.section-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7D8796" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.row-title">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.row-hint">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#8A9AAE" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Styles>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28"
                    MaxWidth="860">
            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="Shortcuts"
                           Classes="page-title" />
                <TextBlock Text="Keep capture keyboard-first. Start with one main hotkey, then adjust activation behavior or add the prompt palette shortcut as needed."
                           Classes="page-subtitle" />
                <TextBlock Text="Single modifier keys like Win are not allowed. Use a combination like Ctrl+Shift, Alt+F9, or Ctrl+Shift+Space."
                           FontSize="11"
                           Foreground="#AFC0D3"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />
            </StackPanel>

            <TextBlock Text="Status"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <StackPanel>
                    <Border Classes="section-row">
                        <StackPanel>
                            <TextBlock Text="Backend" Classes="row-title" />
                            <TextBlock Classes="row-hint"
                                       Text="{Binding ActiveBackendDisplayName, StringFormat='Active: {0}'}" />
                            <TextBlock Classes="row-hint"
                                       Text="{Binding SessionType, StringFormat='Display server: {0}'}" />
                            <TextBlock Classes="row-hint"
                                       Text="{Binding ScopeText, StringFormat='Capture scope: {0}'}" />
                            <TextBlock Classes="row-hint"
                                       Text="{Binding SupportsPressRelease, StringFormat='Press/release support: {0}'}" />
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0"
                            IsVisible="{Binding ShowInputGroupBanner}" />

                    <Border Classes="section-row"
                            IsVisible="{Binding ShowInputGroupBanner}">
                        <StackPanel>
                            <TextBlock Text="⚠ Add your user to the input group to enable global hotkeys"
                                       Classes="row-title"
                                       Foreground="#FFD27A" />
                            <TextBlock TextWrapping="Wrap"
                                       Classes="row-hint"
                                       Text="On Wayland, TypeWhisper needs read access to /dev/input/event* to detect your dictation key while other apps are focused. Run the command below, then log out and back in." />
                            <Border Background="#0E1620"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Margin="0,8,0,0">
                                <SelectableTextBlock Text="{Binding InputGroupCommand}"
                                                     FontFamily="Cascadia Mono, JetBrains Mono, monospace"
                                                     FontSize="12" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0"
                            IsVisible="{Binding ShowCapabilityMismatch}" />

                    <Border Classes="section-row"
                            IsVisible="{Binding ShowCapabilityMismatch}">
                        <StackPanel>
                            <TextBlock Text="⚠ Capability mismatch"
                                       Classes="row-title"
                                       Foreground="#FFD27A" />
                            <TextBlock TextWrapping="Wrap"
                                       Classes="row-hint"
                                       Text="The active backend can only deliver presses, but your activation mode needs release events too. Push-to-talk and Hybrid won't work — switch to Toggle, or enable a backend that supports press+release." />
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="#16FFFFFF" Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Read keyboard events globally on Wayland"
                                           Classes="row-title" />
                                <TextBlock TextWrapping="Wrap"
                                           Classes="row-hint"
                                           Text="When on, TypeWhisper reads /dev/input/event* so the configured hotkey fires regardless of which window has focus. Disable to fall back to focused-only behavior." />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding WaylandEvdevHotkeysEnabled}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Main capture"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <Border Classes="section-row">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="16">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Main dictation hotkey"
                                       Classes="row-title" />
                            <TextBlock Text="Global shortcut that starts dictation. Its behavior depends on the activation mode below."
                                       Classes="row-hint" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <TextBox Width="240"
                                     Text="{Binding HotkeyText}"
                                     PlaceholderText="Ctrl+Shift+Space" />
                            <Button Content="Apply"
                                    Command="{Binding ApplyHotkeyCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>

            <TextBlock Text="More shortcuts"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <StackPanel>
                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Activation mode"
                                           Classes="row-title" />
                                <TextBlock Text="Toggle starts and stops on repeated presses. Push to talk records while held. Hybrid starts immediately, keeps recording after a short press, and stops on release after a long hold."
                                           Classes="row-hint" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="14"
                                        VerticalAlignment="Center">
                                <RadioButton Content="Toggle"
                                             GroupName="mode"
                                             IsChecked="{Binding Mode, Mode=TwoWay,
                                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                                 ConverterParameter={x:Static models:RecordingMode.Toggle}}" />
                                <RadioButton Content="Push to talk"
                                             GroupName="mode"
                                             IsChecked="{Binding Mode, Mode=TwoWay,
                                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                                 ConverterParameter={x:Static models:RecordingMode.PushToTalk}}" />
                                <RadioButton Content="Hybrid"
                                             GroupName="mode"
                                             IsChecked="{Binding Mode, Mode=TwoWay,
                                                                 Converter={x:Static local:EnumBoolConverter.Instance},
                                                                 ConverterParameter={x:Static models:RecordingMode.Hybrid}}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Prompt Palette"
                                           Classes="row-title" />
                                <TextBlock Text="Optional global shortcut that opens the prompt palette for the current selection without starting dictation. Leave blank to disable it."
                                           Classes="row-hint" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBox Width="240"
                                         Text="{Binding PromptPaletteHotkeyText}"
                                         PlaceholderText="Ctrl+Shift+P" />
                                <Button Content="Apply"
                                        Command="{Binding ApplyPromptPaletteHotkeyCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Transform selection"
                                           Classes="row-title" />
                                <TextBlock Text="Optional global shortcut for editing selected text by voice. Leave blank to disable it."
                                           Classes="row-hint" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBox Width="240"
                                         Text="{Binding TransformSelectionHotkeyText}"
                                         PlaceholderText="Ctrl+Shift+T" />
                                <Button Content="Apply"
                                        Command="{Binding ApplyTransformSelectionHotkeyCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Recent transcriptions"
                                           Classes="row-title" />
                                <TextBlock Text="Optional global shortcut that opens a searchable palette of recent transcriptions."
                                           Classes="row-hint" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBox Width="240"
                                         Text="{Binding RecentTranscriptionsHotkeyText}"
                                         PlaceholderText="Ctrl+Shift+R" />
                                <Button Content="Apply"
                                        Command="{Binding ApplyRecentTranscriptionsHotkeyCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="1"
                            Background="#16FFFFFF"
                            Margin="18,0" />

                    <Border Classes="section-row">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="16">
                            <StackPanel Margin="0,0,16,0">
                                <TextBlock Text="Copy last transcription"
                                           Classes="row-title" />
                                <TextBlock Text="Optional global shortcut that copies the latest transcription to the clipboard."
                                           Classes="row-hint" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <TextBox Width="240"
                                         Text="{Binding CopyLastTranscriptionHotkeyText}"
                                         PlaceholderText="Ctrl+Shift+C" />
                                <Button Content="Apply"
                                        Command="{Binding ApplyCopyLastTranscriptionHotkeyCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <TextBlock Text="Bind a custom shortcut"
                       Classes="section-label" />
            <Border Classes="section-panel">
                <Border Classes="section-row">
                    <StackPanel>
                        <StackPanel IsVisible="{Binding CanSetupAutomatically}"
                                    Margin="0,0,0,16">
                            <TextBlock Classes="row-title"
                                       Text="{Binding SetupAutomaticallyLabel}" />
                            <TextBlock Margin="0,4,0,0"
                                       Classes="row-hint"
                                       TextWrapping="Wrap"
                                       Text="Write the dictation shortcut directly to your desktop's settings. The lines below show exactly what will be added — your existing shortcuts are preserved." />

                            <Border Background="#0E1620"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Margin="0,8,0,0">
                                <SelectableTextBlock Text="{Binding IntegrationPreview}"
                                                     FontFamily="Cascadia Mono, JetBrains Mono, monospace"
                                                     FontSize="12"
                                                     TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        Margin="0,10,0,0">
                                <Button Content="{Binding SetupAutomaticallyLabel}"
                                        Command="{Binding SetupAutomaticallyCommand}" />
                                <Button Content="Remove integration"
                                        Command="{Binding RemoveIntegrationCommand}" />
                            </StackPanel>

                            <Border Background="#111822"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,10,0,0"
                                    IsVisible="{Binding IntegrationStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding IntegrationStatusMessage}"
                                           FontSize="12"
                                           Foreground="#AFC0D3"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Border Height="1"
                                    Background="#16FFFFFF"
                                    Margin="0,16,0,0" />
                        </StackPanel>

                        <TextBlock Classes="row-title"
                                   Text="Show me the commands"
                                   IsVisible="{Binding CanSetupAutomatically}"
                                   Margin="0,0,0,6" />
                        <TextBlock TextWrapping="Wrap"
                                   Classes="row-hint"
                                   Margin="0,0,0,10"
                                   Text="You can bind any key combination to toggle dictation through your desktop's keyboard settings. Set the command to:" />

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    Background="#0E1620"
                                    BorderBrush="#1AFFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,6">
                                <SelectableTextBlock Text="{Binding CustomShortcutCommand}"
                                                     FontFamily="Cascadia Mono, JetBrains Mono, monospace"
                                                     FontSize="12" />
                            </Border>
                            <Button Grid.Column="1"
                                    Content="Copy"
                                    Command="{Binding CopyCustomShortcutCommand}" />
                        </Grid>

                        <StackPanel Margin="0,14,0,0"
                                    IsVisible="{Binding ShowPushToTalkSnippet}">
                            <TextBlock Classes="row-hint"
                                       TextWrapping="Wrap"
                                       Text="{Binding PushToTalkSnippetHint}" />

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8"
                                  Margin="0,8,0,0">
                                <Border Grid.Column="0"
                                        Background="#0E1620"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6">
                                    <SelectableTextBlock Text="{Binding PushToTalkPressSnippet}"
                                                         FontFamily="Cascadia Mono, JetBrains Mono, monospace"
                                                         FontSize="12" />
                                </Border>
                                <Button Grid.Column="1"
                                        Content="Copy"
                                        Command="{Binding CopyPushToTalkPressSnippetCommand}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8"
                                  Margin="0,6,0,0">
                                <Border Grid.Column="0"
                                        Background="#0E1620"
                                        BorderBrush="#1AFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6">
                                    <SelectableTextBlock Text="{Binding PushToTalkReleaseSnippet}"
                                                         FontFamily="Cascadia Mono, JetBrains Mono, monospace"
                                                         FontSize="12" />
                                </Border>
                                <Button Grid.Column="1"
                                        Content="Copy"
                                        Command="{Binding CopyPushToTalkReleaseSnippetCommand}" />
                            </Grid>

                            <Button Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Content="Copy both lines"
                                    Command="{Binding CopyPushToTalkPairCommand}" />
                        </StackPanel>

                        <TextBlock Margin="0,12,0,0"
                                   Classes="row-hint"
                                   Text="{Binding DesktopName, StringFormat='Detected desktop: {0}'}" />
                        <TextBlock Margin="0,4,0,0"
                                   Classes="row-hint"
                                   TextWrapping="Wrap"
                                   Text="{Binding DesktopInstructions}" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="11"
                                   Foreground="#7D8796"
                                   TextWrapping="Wrap"
                                   Text="When TypeWhisper is already running, invoking this command toggles dictation in the existing instance — your shortcut won't launch a second copy." />
                    </StackPanel>
                </Border>
            </Border>

            <Border Background="#111822"
                    BorderBrush="#1AFFFFFF"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,12"
                    IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="#AFC0D3"
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
