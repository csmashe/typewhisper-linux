<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TypeWhisper.Linux.ViewModels.Sections"
             x:Class="TypeWhisper.Linux.Views.Sections.ModelsSection"
             x:DataType="vm:ModelsSectionViewModel">
    <DockPanel Margin="16" LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,12">
            <TextBlock Text="Transcription models" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ActiveModelLabel}" FontSize="12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Content="Unload current model" Command="{Binding UnloadModelCommand}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="11" />
            </StackPanel>
        </StackPanel>

        <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Models}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ModelRow">
                            <Border Padding="12,8" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SizeDescription}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Downloaded"
                                               IsVisible="{Binding IsDownloaded}"
                                               VerticalAlignment="Center" Margin="12,0"
                                               Foreground="{DynamicResource SystemAccentColorLight2Brush}" />
                                    <Button Grid.Column="2" Content="Load"
                                            IsVisible="{Binding IsDownloaded}"
                                            Margin="0,0,8,0"
                                            Command="{Binding $parent[ItemsControl].((vm:ModelsSectionViewModel)DataContext).LoadModelCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="3" Content="Download"
                                            IsVisible="{Binding SupportsDownload}"
                                            IsEnabled="{Binding !IsDownloaded}"
                                            Command="{Binding $parent[ItemsControl].((vm:ModelsSectionViewModel)DataContext).DownloadModelCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
