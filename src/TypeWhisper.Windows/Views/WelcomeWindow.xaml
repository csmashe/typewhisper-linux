<ui:FluentWindow x:Class="TypeWhisper.Windows.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        xmlns:plugins="clr-namespace:TypeWhisper.Windows.Services.Plugins"
        Title="{loc:Str Welcome.Title}"
        Width="560" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:StepToVisibilityConverter x:Key="StepConverter"/>
            <conv:LevelToWidthConverter x:Key="LevelToWidth"/>
            <conv:InstallStateToVisibilityConverter x:Key="InstallStateToVis"/>
            <conv:InvertBoolConverter x:Key="InvertBool"/>
            <conv:StringToBrushConverter x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="24,36,24,24">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="TypeWhisper" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{loc:Str Welcome.Subtitle}" Foreground="{StaticResource HintBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Bottom: Navigation -->
        <Grid DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{loc:Str Welcome.Back}" Command="{Binding PreviousStepCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Width="80" Padding="8,4"/>
            <Button Grid.Column="2" Content="{loc:Str Welcome.Skip}" Command="{Binding SkipCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Width="100" Padding="8,4" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="{loc:Str Welcome.Next}" Command="{Binding NextStepCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Width="80" Padding="8,4"/>
        </Grid>

        <!-- Steps indicator (4 steps) -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Ellipse Width="10" Height="10" Margin="4">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#555"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="0">
                                <Setter Property="Fill" Value="#5865F2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <Ellipse Width="10" Height="10" Margin="4">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#555"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                <Setter Property="Fill" Value="#5865F2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <Ellipse Width="10" Height="10" Margin="4">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#555"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                <Setter Property="Fill" Value="#5865F2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <Ellipse Width="10" Height="10" Margin="4">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="#555"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                <Setter Property="Fill" Value="#5865F2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
        </StackPanel>

        <!-- Content area -->
        <Grid>
            <!-- Step 0: Extensions + Model -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding CurrentStep, Converter={StaticResource StepConverter}, ConverterParameter=0}">
                <StackPanel>
                    <TextBlock Text="{loc:Str Welcome.Step1Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{loc:Str Welcome.Step1Desc}"
                               TextWrapping="Wrap" Foreground="{StaticResource HintBrush}" Margin="0,0,0,12"/>

                    <!-- Extensions list -->
                    <TextBlock Text="{loc:Str Welcome.ExtensionsHeader}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource LabelBrush}" Margin="0,0,0,6"/>

                    <ItemsControl ItemsSource="{Binding Plugins}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource InputBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                    <DockPanel>
                                        <!-- Install/Installed badge -->
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <!-- Install button -->
                                            <Button Content="{loc:Str Welcome.Install}"
                                                    Command="{Binding InstallCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Padding="10,4" FontSize="11"
                                                    IsEnabled="{Binding IsWorking, Converter={StaticResource InvertBool}}"
                                                    Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=NotInstalled}"/>
                                            <!-- Installed label -->
                                            <TextBlock Text="{loc:Str Welcome.Installed}" FontSize="11"
                                                       Foreground="#44cc44" FontWeight="SemiBold"
                                                       Visibility="{Binding InstallState, Converter={StaticResource InstallStateToVis}, ConverterParameter=Installed}"/>
                                        </StackPanel>

                                        <!-- Icon + Info -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding IconEmoji}" FontSize="18" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}">
                                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                                    <Run Text="{Binding SizeDisplay, Mode=OneWay}" Foreground="{StaticResource HintBrush}" FontWeight="Normal" FontSize="11"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{StaticResource HintBrush}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- Progress bar for installing -->
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Model selection (only when engines available) -->
                    <TextBlock Text="{loc:Str Welcome.ModelHeader}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource LabelBrush}" Margin="0,14,0,6"/>

                    <!-- No models hint -->
                    <TextBlock Text="{loc:Str Welcome.NoModels}" FontSize="11" FontStyle="Italic"
                               Foreground="{StaticResource HintBrush}" Margin="0,0,0,8"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvailableModels.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ComboBox ItemsSource="{Binding AvailableModels}"
                              SelectedValue="{Binding SelectedModelId}"
                              SelectedValuePath="FullModelId"
                              DisplayMemberPath="DisplayName"
                              MinHeight="36" Margin="0,0,0,8">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvailableModels.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <Button Content="{loc:Str Welcome.Download}" Command="{Binding DownloadModelCommand}"
                            Width="140" HorizontalAlignment="Left" Padding="12,6">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AvailableModels.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="1" Height="6"
                                 Margin="0,8,0,4" Background="#333" Foreground="{StaticResource AccentBrush}"
                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding DownloadStatus}" Foreground="{StaticResource HintBrush}" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Step 1: Microphone test -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepConverter}, ConverterParameter=1}">
                <TextBlock Text="{loc:Str Welcome.Step2Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="{loc:Str Welcome.Step2Desc}"
                           TextWrapping="Wrap" Foreground="{StaticResource HintBrush}" Margin="0,0,0,12"/>

                <Border Height="20" CornerRadius="4" Background="#333" Margin="0,0,0,8">
                    <Border CornerRadius="4" Background="#44cc44" HorizontalAlignment="Left"
                            Width="{Binding MicLevel, Converter={StaticResource LevelToWidth}}"/>
                </Border>

                <TextBlock Text="{loc:Str Welcome.MicWorks}" Foreground="Green" FontWeight="SemiBold"
                           Visibility="{Binding MicWorking, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- Step 2: Hotkey config -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepConverter}, ConverterParameter=2}">
                <TextBlock Text="{loc:Str Welcome.Step3Title}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="{loc:Str Welcome.Step3Desc}"
                           TextWrapping="Wrap" Foreground="{StaticResource HintBrush}" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{loc:Str Welcome.ToggleHotkeyLabel}" VerticalAlignment="Center"
                               Foreground="{StaticResource LabelBrush}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ToggleHotkey}" Width="200" HorizontalAlignment="Left"
                             Style="{StaticResource InputTextBoxStyle}"/>

                    <TextBlock Grid.Row="1" Text="{loc:Str Welcome.PttLabel}" VerticalAlignment="Center" Margin="0,8,0,0"
                               Foreground="{StaticResource LabelBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PushToTalkHotkey}" Width="200"
                             HorizontalAlignment="Left" Margin="0,8,0,0"
                             Style="{StaticResource InputTextBoxStyle}"/>
                </Grid>
            </StackPanel>

            <!-- Step 3: Done -->
            <StackPanel Visibility="{Binding CurrentStep, Converter={StaticResource StepConverter}, ConverterParameter=3}"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{loc:Str Welcome.AllSet}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="{loc:Str Welcome.AllSetDesc}"
                           TextWrapping="Wrap" Foreground="{StaticResource HintBrush}" HorizontalAlignment="Center" Margin="0,8,0,16"/>
                <Button Content="{loc:Str Welcome.GetStarted}" Command="{Binding SkipCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Width="120" HorizontalAlignment="Center" Padding="12,8" FontSize="14"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
