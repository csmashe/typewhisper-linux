<UserControl x:Class="TypeWhisper.Windows.Views.Sections.PromptsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="24">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="{loc:Str Prompts.Title}" Style="{StaticResource SectionHeaderStyle}"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="{loc:Str Prompts.Subtitle}"
                   Style="{StaticResource HintStyle}" Margin="0,0,0,12"/>

        <!-- Warning: No LLM provider -->
        <ui:InfoBar DockPanel.Dock="Top"
                    Title="{loc:Str Prompts.NoLlmProvider}"
                    Message="{loc:Str Prompts.NoLlmProviderHint}"
                    Severity="Warning" IsOpen="True" IsClosable="False"
                    Margin="0,0,0,12"
                    Visibility="{Binding Prompts.HasLlmProviders, Converter={StaticResource InverseBoolToVis}}"/>

        <!-- Default LLM Provider -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16"
                    Visibility="{Binding Prompts.HasLlmProviders, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{loc:Str Prompts.DefaultProvider}" Style="{StaticResource LabelStyle}"/>
            <ComboBox ItemsSource="{Binding Prompts.AvailableProviders}"
                      SelectedValue="{Binding Prompts.DefaultLlmProvider}"
                      SelectedValuePath="Value"
                      DisplayMemberPath="DisplayName"
                      Width="320" HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Editor Panel -->
        <Border DockPanel.Dock="Top"
                Background="#18FFFFFF" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                Visibility="{Binding Prompts.IsEditorOpen, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock x:Name="EditorTitle"
                           Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Icon picker -->
                <TextBlock Text="{loc:Str Prompts.Icon}" Style="{StaticResource LabelStyle}"/>
                <ItemsControl ItemsSource="{x:Static vm:PromptsViewModel.IconOptions}" Margin="0,0,0,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" FontSize="18" Padding="4,2" Margin="2"
                                    Click="IconPick_Click"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="6,3">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Name -->
                <TextBlock Text="{loc:Str Prompts.NameLabel}" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Prompts.EditName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10"/>

                <!-- System Prompt -->
                <TextBlock Text="{loc:Str Prompts.SystemPrompt}" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Prompts.EditSystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBoxStyle}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="80" MaxHeight="160"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,10"/>

                <!-- Provider override -->
                <TextBlock Text="{loc:Str Prompts.ProviderOverride}" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Prompts.AvailableProviders}"
                          SelectedValue="{Binding Prompts.EditProviderOverride}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="DisplayName"
                          Width="320" HorizontalAlignment="Left"
                          Margin="0,0,0,12"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="{loc:Str Prompts.Cancel}"
                              Command="{Binding Prompts.CancelEditorCommand}"
                              Appearance="Secondary" Padding="12,6" Margin="0,0,8,0"/>
                    <ui:Button Content="{loc:Str Prompts.Save}"
                              Command="{Binding Prompts.SaveEditorCommand}"
                              Appearance="Primary" Padding="12,6"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12"
              Visibility="{Binding Prompts.IsEditorOpen, Converter={StaticResource InverseBoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="1" Content="{loc:Str Prompts.New}"
                      Command="{Binding Prompts.StartCreateCommand}"
                      Appearance="Primary" Padding="12,6"/>
        </Grid>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <TextBlock Text="{loc:Str Prompts.EmptyTitle}"
                       Foreground="#808080" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <ui:Button Content="{loc:Str Prompts.CreateFirst}"
                      Command="{Binding Prompts.StartCreateCommand}"
                      Appearance="Primary" Padding="16,8"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Actions List -->
        <ScrollViewer x:Name="ActionList" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Prompts.Actions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TimelineCardStyle}" Margin="0,0,0,6"
                                MouseLeftButtonDown="Card_MouseLeftButtonDown">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{loc:Str Prompts.ContextEdit}" Click="ContextEdit_Click"/>
                                    <MenuItem Header="{loc:Str Prompts.ContextMoveUp}" Click="ContextMoveUp_Click"/>
                                    <MenuItem Header="{loc:Str Prompts.ContextMoveDown}" Click="ContextMoveDown_Click"/>
                                    <Separator/>
                                    <MenuItem Header="{loc:Str Prompts.ContextDelete}" Click="ContextDelete_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                           FontSize="20" VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>

                                <!-- Name + Prompt preview -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SystemPrompt}"
                                               Foreground="#808080" FontSize="11"
                                               TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                                </StackPanel>

                                <!-- Toggle Enabled -->
                                <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                 VerticalAlignment="Center" Margin="8,0,0,0"
                                                 Checked="ToggleEnabled_Click" Unchecked="ToggleEnabled_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
