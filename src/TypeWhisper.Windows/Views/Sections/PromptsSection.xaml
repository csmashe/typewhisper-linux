<UserControl x:Class="TypeWhisper.Windows.Views.Sections.PromptsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsSummaryBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,18,0">
                    <TextBlock Text="{loc:Str Prompts.Title}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Prompts.SummaryText}" Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="{loc:Str Prompts.Subtitle}" Style="{StaticResource HintStyle}" Margin="0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding Prompts.HasLlmProviders, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{loc:Str Prompts.DefaultProvider}" Style="{StaticResource HintStyle}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Prompts.AvailableProviders}"
                              SelectedValue="{Binding Prompts.DefaultLlmProvider}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource SettingsAlignedComboBoxStyle}"
                              Width="280"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="{loc:Str Prompts.New}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Prompts.StartCreateCommand}"
                        Padding="14,7"
                        FontSize="12"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ui:InfoBar Grid.Row="1"
                    Title="{loc:Str Prompts.NoLlmProvider}"
                    Message="{loc:Str Prompts.NoLlmProviderHint}"
                    Severity="Warning"
                    IsOpen="True"
                    IsClosable="False"
                    Margin="0,0,0,16"
                    Visibility="{Binding Prompts.HasLlmProviders, Converter={StaticResource InverseBoolToVis}}"/>

        <Grid Grid.Row="2">
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="360"
                        Visibility="Collapsed">
                <TextBlock Text=""
                           FontFamily="Segoe Fluent Icons"
                           FontSize="34"
                           Foreground="{StaticResource HintBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{loc:Str Prompts.EmptyTitle}"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{loc:Str Prompts.EmptySubtitle}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextAlignment="Center"
                           Margin="0,0,0,18"/>
                <Button Content="{loc:Str Prompts.CreateFirst}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Prompts.StartCreateCommand}"
                        Padding="16,8"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <Border x:Name="ActionListHost"
                    Style="{StaticResource SettingsGroupPanelStyle}"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ActionList"
                                  ItemsSource="{Binding Prompts.Actions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SettingsCollectionRowStyle}"
                                        MouseLeftButtonDown="Card_MouseLeftButtonDown"
                                        Cursor="Hand">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{loc:Str Prompts.ContextEdit}" Click="ContextEdit_Click"/>
                                            <MenuItem Header="{loc:Str Prompts.ContextMoveUp}" Click="ContextMoveUp_Click"/>
                                            <MenuItem Header="{loc:Str Prompts.ContextMoveDown}" Click="ContextMoveDown_Click"/>
                                            <Separator/>
                                            <MenuItem Header="{loc:Str Prompts.ContextDelete}" Click="ContextDelete_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="36"
                                                Height="36"
                                                CornerRadius="10"
                                                Background="#162338"
                                                BorderBrush="#24507BAA"
                                                BorderThickness="1"
                                                Margin="0,0,14,0">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="18"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <Border Style="{StaticResource BadgeStyle}"
                                                        Margin="8,0,0,0"
                                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{loc:Str Prompts.EnabledBadge}"
                                                               Foreground="#D6DEE9"
                                                               FontSize="10"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SystemPrompt}"
                                                       Foreground="{StaticResource HintBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="18"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="{loc:Str Prompts.ContextEdit}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.Prompts.StartEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="12,6"
                                                FontSize="12"
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center"/>

                                        <ui:ToggleSwitch Grid.Column="3"
                                                         IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         Checked="ToggleEnabled_Click"
                                                         Unchecked="ToggleEnabled_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
