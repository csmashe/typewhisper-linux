<UserControl x:Class="TypeWhisper.Windows.Views.Sections.RecorderSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="600" Margin="24">
            <TextBlock Text="{loc:Str Nav.Recorder}" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Record audio and transcribe it."
                       Style="{StaticResource HintStyle}" Margin="0,0,0,24"/>

            <!-- Recording controls -->
            <Border Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24" HorizontalAlignment="Center" Margin="0,0,0,24">
                <StackPanel HorizontalAlignment="Center">
                    <!-- Duration -->
                    <TextBlock Text="{Binding Recorder.DurationText}"
                               FontSize="48" FontFamily="Consolas"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Record/Stop button -->
                    <ui:Button Appearance="Primary"
                               Command="{Binding Recorder.ToggleRecordingCommand}"
                               HorizontalAlignment="Center"
                               Padding="24,12" FontSize="14">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x23FA;" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Record"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Recorder.IsRecording}" Value="True">
                                                    <Setter Property="Text" Value="Stop"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>

                    <!-- Level meter -->
                    <ProgressBar Value="{Binding Recorder.AudioLevel}" Maximum="1" Height="4"
                                 Margin="0,16,0,0" Width="200"
                                 Visibility="{Binding Recorder.IsRecording, Converter={StaticResource BoolToVis}}"/>

                    <!-- Status -->
                    <TextBlock Text="{Binding Recorder.StatusText}"
                               Foreground="{StaticResource HintBrush}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Recordings list -->
            <TextBlock Text="Recordings" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"
                       Visibility="{Binding Recorder.HasRecordings, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>

            <ItemsControl ItemsSource="{Binding Recorder.Recordings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="{Binding Transcript}" FontSize="11"
                                               Foreground="{StaticResource HintBrush}"
                                               TextTrimming="CharacterEllipsis" MaxHeight="32"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                               FontSize="10" Foreground="{StaticResource HintBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ui:Button Grid.Column="1" Appearance="Secondary"
                                           ToolTip="Delete" Padding="6,4"
                                           VerticalAlignment="Center"
                                           Command="{Binding DataContext.Recorder.DeleteRecordingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}">
                                    <ui:SymbolIcon Symbol="Delete24"/>
                                </ui:Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
