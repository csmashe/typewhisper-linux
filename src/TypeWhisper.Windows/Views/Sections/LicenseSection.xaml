<UserControl x:Class="TypeWhisper.Windows.Views.Sections.LicenseSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="500" Margin="24" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{loc:Str Nav.License}" Style="{StaticResource SectionHeaderStyle}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="TypeWhisper is free and open source."
                       Foreground="{StaticResource HintBrush}" FontSize="14"
                       HorizontalAlignment="Center" Margin="0,8,0,24"/>

            <!-- License key input -->
            <Border Background="{StaticResource InputBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Supporter License" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter a Polar.sh license key to unlock supporter features and badges."
                               Foreground="{StaticResource HintBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <TextBlock Text="License Key" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="LicenseKeyBox" MaxLength="200" Grid.Column="0"/>
                        <ui:Button Grid.Column="1" Content="Activate" Appearance="Primary"
                                   Margin="8,0,0,0" Padding="16,6"
                                   Click="OnActivateClick"/>
                    </Grid>

                    <TextBlock x:Name="LicenseStatus"
                               Foreground="{StaticResource HintBrush}" FontSize="12"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Open source info -->
            <TextBlock Foreground="{StaticResource HintBrush}" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center">
                <Run Text="License: GPL-3.0-or-later"/>
                <LineBreak/>
                <Run Text="Source: github.com/TypeWhisper/typewhisper-win"/>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
