<UserControl x:Class="TypeWhisper.Windows.Views.Sections.SnippetsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis"/>
            <conv:TagSplitConverter x:Key="TagSplitConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SettingsSummaryBarStyle}">
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,18,0">
                <TextBlock Text="{loc:Str Snippets.Title}"
                           Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Snippets.SummaryText}"
                           Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,4"/>
                <TextBlock Text="{loc:Str Snippets.Subtitle}"
                           Style="{StaticResource HintStyle}" Margin="0,0,0,4"/>
                <TextBlock Text="{loc:Str Snippets.Hint}"
                           Style="{StaticResource HintStyle}" Margin="0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="{loc:Str Snippets.Import}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding Snippets.ImportSnippetsCommand}"
                    Padding="12,7" FontSize="12" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="{loc:Str Snippets.Export}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding Snippets.ExportSnippetsCommand}"
                    Padding="12,7" FontSize="12" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="{loc:Str Snippets.New}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding Snippets.StartCreateCommand}"
                    Padding="14,7" FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SettingsFilterRowStyle}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{loc:Str Snippets.TagFilter}"
                           Style="{StaticResource HintStyle}"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          Style="{StaticResource SettingsCompactComboBoxStyle}"
                          Width="180"
                          SelectedItem="{Binding Snippets.SelectedTagFilter}"
                          ItemsSource="{Binding Snippets.AvailableTags}"
                          IsEditable="False"/>
                <Button Grid.Column="2" Content="{loc:Str Snippets.AllTags}"
                        Style="{StaticResource LinkButtonStyle}"
                        Command="{Binding Snippets.ClearTagFilterCommand}"
                        Margin="8,0,0,0"
                        Visibility="{Binding Snippets.SelectedTagFilter, Converter={StaticResource NonEmptyToVis}}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="360"
                        Visibility="Collapsed">
                <TextBlock Text=""
                           FontFamily="Segoe Fluent Icons"
                           FontSize="34"
                           Foreground="{StaticResource HintBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="{loc:Str Snippets.EmptyTitle}"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{loc:Str Snippets.EmptySubtitle}"
                           Style="{StaticResource PageSubtitleStyle}"
                           TextAlignment="Center"
                           Margin="0,0,0,18"/>
                <Button Content="{loc:Str Snippets.CreateFirst}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Snippets.StartCreateCommand}"
                        Padding="16,8"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <Border x:Name="SnippetListHost"
                    Style="{StaticResource SettingsGroupPanelStyle}"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Snippets.Snippets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                        MouseLeftButtonDown="Card_MouseLeftButtonDown"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SettingsCollectionRowStyle}">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.62"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{loc:Str Snippets.ContextEdit}" Click="ContextEdit_Click"/>
                                            <MenuItem Header="{loc:Str Snippets.ContextDelete}" Click="ContextDelete_Click"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="#14337FD8"
                                                BorderBrush="#225E9FF2"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="9,4"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Trigger}"
                                                       FontFamily="Consolas"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="→"
                                                   Foreground="{StaticResource HintBrush}"
                                                   FontSize="12"
                                                   VerticalAlignment="Top"
                                                   Margin="12,4,14,0"/>

                                        <StackPanel Grid.Column="2" Margin="0,0,14,0">
                                            <TextBlock Text="{Binding Replacement}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Replacement}"/>
                                            <WrapPanel Margin="0,7,0,0">
                                                <Border Style="{StaticResource BadgeStyle}"
                                                        Margin="0,0,6,0"
                                                        Visibility="{Binding CaseSensitive, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="Aa"
                                                               Foreground="#D6DEE9"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding UsageCount, StringFormat={}{0}x}"
                                                               Foreground="#D6DEE9"
                                                               FontSize="10"/>
                                                </Border>
                                                <ItemsControl ItemsSource="{Binding Tags, Converter={StaticResource TagSplitConverter}}"
                                                              Visibility="{Binding Tags, Converter={StaticResource NonEmptyToVis}}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding}" Foreground="#D6DEE9" FontSize="10"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                Content="{loc:Str Snippets.ContextEdit}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.Snippets.EditItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="12,6"
                                                FontSize="12"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"/>

                                        <Button Grid.Column="4"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.Snippets.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{loc:Str Snippets.ContextDelete}"
                                                Padding="10,6"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text=""
                                                       FontFamily="Segoe Fluent Icons"
                                                       FontSize="12"
                                                       Foreground="{StaticResource LabelBrush}"/>
                                        </Button>

                                        <ui:ToggleSwitch Grid.Column="5"
                                                         IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         Checked="ToggleEnabled_Click"
                                                         Unchecked="ToggleEnabled_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
