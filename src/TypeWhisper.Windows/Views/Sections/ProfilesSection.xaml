<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ProfilesSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:ProfileSubtitleConverter x:Key="ProfileSubtitleConverter"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility"/>

            <Style x:Key="ChipRemoveButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="4,0,0,0"/>
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="9"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DangerLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource LinkButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SettingsGroupPanelStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SettingsRowBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{loc:Str Profiles.Title}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Profiles.ProfileSummary}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="1"
                         Margin="10,8,10,8"
                         ItemsSource="{Binding Profiles.Profiles}"
                         SelectedItem="{Binding Profiles.SelectedProfile}"
                         Style="{StaticResource MasterListBoxStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Converter={StaticResource ProfileSubtitleConverter}}" FontSize="11" Foreground="{StaticResource HintBrush}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                 VerticalAlignment="Center"
                                                 Checked="ProfileToggle_Changed"
                                                 Unchecked="ProfileToggle_Changed"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2" Style="{StaticResource SettingsStickyFooterStyle}">
                    <Button Content="{loc:Str Profiles.NewProfile}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding Profiles.AddProfileCommand}"
                            Padding="12,8"
                            HorizontalAlignment="Stretch"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MaxWidth="380">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SettingsSummaryBarStyle}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Profiles.SelectedProfile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{loc:Str Profiles.SelectProfile}" Style="{StaticResource SettingsGroupTitleStyle}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="{loc:Str Profiles.SelectProfileHint}" Style="{StaticResource PageSubtitleStyle}" TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Profiles.SelectedProfile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SettingsSummaryBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{Binding Profiles.EditName}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Profiles.SelectedProfileSummary}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1"
                                     IsChecked="{Binding Profiles.EditIsEnabled}"
                                     OnContent="{loc:Str Profiles.EnabledLabel}"
                                     OffContent="{loc:Str Profiles.EnabledLabel}"
                                     VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel MaxWidth="860">
                    <TextBlock Text="{loc:Str Profiles.MatchSection}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <StackPanel Margin="18,16">
                            <TextBlock Text="{loc:Str Profiles.Name}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Profiles.EditName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsCompactTextBoxStyle}" Margin="0,0,0,14"/>

                            <TextBlock Text="{loc:Str Profiles.Apps}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Profiles.ProcessNameChips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding}" Foreground="#D6DEE9" FontSize="10.5"/>
                                                <Button Content="&#xE711;"
                                                        Style="{StaticResource ChipRemoveButtonStyle}"
                                                        Command="{Binding DataContext.Profiles.RemoveProcessNameChipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox x:Name="ProcessNameInputBox"
                                     Text="{Binding Profiles.ProcessNameInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsCompactTextBoxStyle}"
                                     KeyDown="ProcessNameInputBox_KeyDown"/>
                            <TextBlock Text="{loc:Str Profiles.ProcessNameHint}" Style="{StaticResource HintStyle}" Margin="0,8,0,0"/>

                            <ItemsControl ItemsSource="{Binding Profiles.RunningApps}" Margin="0,8,0,14">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding DataContext.Profiles.AddRunningAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="10,4"
                                                FontSize="11.5"
                                                Margin="0,0,6,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{loc:Str Profiles.UrlPatterns}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Profiles.UrlPatternChips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource BadgeStyle}" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding}" Foreground="#D6DEE9" FontSize="10.5"/>
                                                <Button Content="&#xE711;"
                                                        Style="{StaticResource ChipRemoveButtonStyle}"
                                                        Command="{Binding DataContext.Profiles.RemoveUrlPatternChipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox x:Name="UrlPatternInputBox"
                                     Text="{Binding Profiles.UrlPatternInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsCompactTextBoxStyle}"
                                     KeyDown="UrlPatternInputBox_KeyDown"/>
                            <TextBlock Text="{loc:Str Profiles.UrlPatternHint}" Style="{StaticResource HintStyle}" Margin="0,8,0,14"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Str Profiles.ActiveWindow}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBlock Foreground="{StaticResource LabelBrush}" FontSize="11.5" TextTrimming="CharacterEllipsis">
                                        <Run Text="&#xE8B7; " FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                        <Run Text="{Binding Profiles.CurrentProcessName}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11.5" Margin="0,4,0,0" TextTrimming="CharacterEllipsis">
                                        <Run Text="&#xE8A7; " FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                        <Run Text="{Binding Profiles.CurrentWindowTitle}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#88FFCC"
                                               FontSize="11.5"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Profiles.CurrentUrl, Converter={StaticResource NonEmptyToVisibility}}">
                                        <Run Text="&#xE774; " FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                        <Run Text="{Binding Profiles.CurrentUrl}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1" Padding="10,6" CornerRadius="999" VerticalAlignment="Top">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1AD95D66"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Profiles.HasMatchedProfile}" Value="True">
                                                    <Setter Property="Background" Value="#1739B980"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Profiles.MatchStatusText}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Profiles.HasMatchedProfile}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource ActiveIndicatorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str Profiles.Overrides}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str Profiles.LanguageLabel}" Style="{StaticResource SettingsRowLabelStyle}" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" SelectedValue="{Binding Profiles.EditLanguage}" SelectedValuePath="Tag" Style="{StaticResource SettingsAlignedComboBoxStyle}">
                                        <ComboBoxItem Content="{loc:Str Profiles.GlobalSetting}" Tag="{x:Null}"/>
                                        <ComboBoxItem Content="{loc:Str Profiles.Auto}" Tag="auto"/>
                                        <ComboBoxItem Content="Deutsch" Tag="de"/>
                                        <ComboBoxItem Content="English" Tag="en"/>
                                        <ComboBoxItem Content="Français" Tag="fr"/>
                                        <ComboBoxItem Content="Español" Tag="es"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.TaskLabel}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.TaskHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1" SelectedValue="{Binding Profiles.EditTask}" SelectedValuePath="Tag" Style="{StaticResource SettingsAlignedComboBoxStyle}">
                                        <ComboBoxItem Content="{loc:Str Profiles.TaskGlobal}" Tag="{x:Null}"/>
                                        <ComboBoxItem Content="{loc:Str Profiles.TaskTranscribe}" Tag="transcribe"/>
                                        <ComboBoxItem Content="{loc:Str Profiles.TaskTranslate}" Tag="translate"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.TranslationLabel}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.TranslationOverrideHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Profiles.TranslationTargetOptions}"
                                              SelectedValue="{Binding Profiles.EditTranslationTarget}"
                                              SelectedValuePath="Code"
                                              TextSearch.TextPath="DisplayName"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.WhisperModeOverride}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.WhisperModeOverrideHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Profiles.EditWhisperModeOverride}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.TranscriptionModel}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.TranscriptionModelHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Profiles.AvailableModelOptions}"
                                              SelectedValue="{Binding Profiles.EditTranscriptionModelOverride}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str Profiles.ActivationSection}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{loc:Str Profiles.EnabledLabel}" Style="{StaticResource SettingsRowLabelStyle}" VerticalAlignment="Center"/>
                                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding Profiles.EditIsEnabled}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.HotkeyLabel}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.HotkeyHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <controls:HotkeyRecorderControl Grid.Column="1" Hotkey="{Binding Profiles.EditHotkey, Mode=TwoWay}" HorizontalAlignment="Right" Width="250"/>
                                </Grid>
                            </Border>
                            <Border Height="1" Background="#16FFFFFF"/>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Profiles.Priority}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Profiles.PriorityHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Text="{Binding Profiles.EditPriority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SettingsNumericTextBoxStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{loc:Str Profiles.ActionsSection}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsSectionFormStyle}">
                        <Grid Margin="18,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="{loc:Str Profiles.ActionsSection}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                <TextBlock Text="{loc:Str Profiles.ActionsHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="{loc:Str Profiles.Duplicate}"
                                    Style="{StaticResource LinkButtonStyle}"
                                    Command="{Binding Profiles.DuplicateProfileCommand}"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="{loc:Str Profiles.Delete}"
                                    Style="{StaticResource DangerLinkButtonStyle}"
                                    Command="{Binding Profiles.DeleteProfileCommand}"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Style="{StaticResource SettingsStickyFooterStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Str Profiles.SaveHint}" Style="{StaticResource HintStyle}" Margin="0" VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="{loc:Str Profiles.Save}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding Profiles.SaveProfileCommand}"
                            Padding="16,8"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
