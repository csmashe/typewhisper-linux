<UserControl x:Class="TypeWhisper.Windows.Views.Sections.GeneralSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:models="clr-namespace:TypeWhisper.Core.Models;assembly=TypeWhisper.Core"
             xmlns:vms="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="500" Margin="24">
            <TextBlock Text="{loc:Str General.Title}" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Hotkey (Hybrid) -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.HotkeyHybrid}" Style="{StaticResource LabelStyle}"/>
                <controls:HotkeyRecorderControl
                    Hotkey="{Binding Settings.PushToTalkHotkey}" AllowModifierOnly="True"
                    Width="200" HorizontalAlignment="Left"/>
                <TextBlock Text="{loc:Str General.HotkeyHybridHint}"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <!-- Toggle-Hotkey -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.ToggleHotkey}" Style="{StaticResource LabelStyle}"/>
                <controls:HotkeyRecorderControl
                    Hotkey="{Binding Settings.ToggleOnlyHotkey}" AllowModifierOnly="True"
                    Width="200" HorizontalAlignment="Left"/>
                <TextBlock Text="{loc:Str General.ToggleHotkeyHint}"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <!-- Hold-Hotkey -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.HoldHotkey}" Style="{StaticResource LabelStyle}"/>
                <controls:HotkeyRecorderControl
                    Hotkey="{Binding Settings.HoldOnlyHotkey}" AllowModifierOnly="True"
                    Width="200" HorizontalAlignment="Left"/>
                <TextBlock Text="{loc:Str General.HoldHotkeyHint}"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <!-- Prompt-Palette Hotkey -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.PromptPalette}" Style="{StaticResource LabelStyle}"/>
                <controls:HotkeyRecorderControl
                    Hotkey="{Binding Settings.PromptPaletteHotkey}" AllowModifierOnly="True"
                    Width="200" HorizontalAlignment="Left"/>
                <TextBlock Text="{loc:Str General.PromptPaletteHint}"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <!-- Language -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.Language}" Style="{StaticResource LabelStyle}"/>
                <ComboBox SelectedValue="{Binding Settings.Language}" SelectedValuePath="Tag"
                          Width="280" HorizontalAlignment="Left">
                    <ComboBoxItem Content="{loc:Str General.LanguageAuto}" Tag="auto"/>
                    <ComboBoxItem Content="Deutsch" Tag="de"/>
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="Français" Tag="fr"/>
                    <ComboBoxItem Content="Español" Tag="es"/>
                    <ComboBoxItem Content="Italiano" Tag="it"/>
                    <ComboBoxItem Content="Português" Tag="pt"/>
                    <ComboBoxItem Content="Nederlands" Tag="nl"/>
                    <ComboBoxItem Content="Polski" Tag="pl"/>
                    <ComboBoxItem Content="Čeština" Tag="cs"/>
                    <ComboBoxItem Content="Svenska" Tag="sv"/>
                    <ComboBoxItem Content="Dansk" Tag="da"/>
                    <ComboBoxItem Content="Suomi" Tag="fi"/>
                </ComboBox>
            </StackPanel>

            <!-- Behavior -->
            <TextBlock Text="{loc:Str General.Behavior}" Style="{StaticResource SectionHeaderStyle}"/>
            <StackPanel Margin="0,0,0,8">
                <ui:ToggleSwitch IsChecked="{Binding Settings.AutoPaste}"
                                 OnContent="{loc:Str General.AutoPaste}"
                                 OffContent="{loc:Str General.AutoPaste}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
                <ui:ToggleSwitch IsChecked="{Binding Settings.WhisperModeEnabled}"
                                 OnContent="{loc:Str General.WhisperMode}"
                                 OffContent="{loc:Str General.WhisperMode}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
                <ui:ToggleSwitch IsChecked="{Binding Settings.SoundFeedbackEnabled}"
                                 OnContent="{loc:Str General.SoundFeedback}"
                                 OffContent="{loc:Str General.SoundFeedback}"/>
            </StackPanel>

            <!-- Translation -->
            <TextBlock Text="{loc:Str General.Translation}" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,16"/>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.TargetLanguage}" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Settings.TranslationTargetOptions}"
                          SelectedValue="{Binding Settings.TranslationTargetLanguage}"
                          SelectedValuePath="Code"
                          IsTextSearchEnabled="True" TextSearch.TextPath="DisplayName"
                          Width="280" HorizontalAlignment="Left">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#2D5A8E" CornerRadius="3" Padding="5,1" MinWidth="28"
                                        Margin="0,0,8,0" VerticalAlignment="Center"
                                        Visibility="{Binding BadgeText, Converter={StaticResource NonEmptyToVisibility}}">
                                    <TextBlock Text="{Binding BadgeText}" FontSize="10" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               FontFamily="Consolas"/>
                                </Border>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{loc:Str General.TranslationHint}"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <!-- Overlay -->
            <TextBlock Text="{loc:Str General.Overlay}" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,16"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{loc:Str General.Position}" Style="{StaticResource LabelStyle}"/>
                    <ComboBox SelectedValue="{Binding Settings.OverlayPosition}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="{loc:Str General.PositionTop}" Tag="{x:Static models:OverlayPosition.Top}"/>
                        <ComboBoxItem Content="{loc:Str General.PositionBottom}" Tag="{x:Static models:OverlayPosition.Bottom}"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{loc:Str General.LeftWidget}" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{x:Static vms:SettingsViewModel.WidgetOptions}"
                              SelectedValue="{Binding Settings.OverlayLeftWidget}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="{loc:Str General.RightWidget}" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{x:Static vms:SettingsViewModel.WidgetOptions}"
                              SelectedValue="{Binding Settings.OverlayRightWidget}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"/>
                </StackPanel>
            </Grid>

            <!-- Overlay Preview -->
            <TextBlock Text="{loc:Str General.Preview}" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
            <Border Background="#20000000" CornerRadius="8" Padding="24,20" Margin="0,0,0,20"
                    HorizontalAlignment="Center" MinWidth="400">
                <Border Background="#F0181818" CornerRadius="22" Padding="14,10"
                        HorizontalAlignment="Center" MinWidth="280"
                        BorderBrush="#25FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left widget placeholder -->
                        <Border Grid.Column="0" Width="14" Height="14" CornerRadius="7"
                                Background="#FF4CAF50" Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                ToolTip="{Binding Settings.OverlayLeftWidget}"/>

                        <!-- Status text -->
                        <TextBlock Grid.Column="1" Text="Recording..."
                                   Foreground="#CCFFFFFF" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <!-- Right widget placeholder -->
                        <TextBlock Grid.Column="2" Text="0:03" FontSize="12"
                                   Foreground="#99FFFFFF" VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   ToolTip="{Binding Settings.OverlayRightWidget}"/>
                    </Grid>
                </Border>
            </Border>

            <!-- System -->
            <TextBlock Text="{loc:Str General.System}" Style="{StaticResource SectionHeaderStyle}"/>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="{loc:Str General.UiLanguage}" Style="{StaticResource LabelStyle}"/>
                <ComboBox ItemsSource="{Binding Source={x:Static loc:Loc.Instance}, Path=AvailableUiLanguages}"
                          SelectedValue="{Binding Settings.UiLanguage}"
                          SelectedValuePath="Code"
                          DisplayMemberPath="DisplayName"
                          Width="200" HorizontalAlignment="Left"/>
                <TextBlock Text="{loc:Str General.UiLanguageHint}" Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,8">
                <ui:ToggleSwitch IsChecked="{Binding Settings.AutostartEnabled}"
                                 OnContent="{loc:Str General.Autostart}"
                                 OffContent="{loc:Str General.Autostart}"/>
            </StackPanel>

            <!-- API Server -->
            <TextBlock Text="{loc:Str General.ApiServer}" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,16"/>
            <StackPanel Margin="0,0,0,8">
                <ui:ToggleSwitch IsChecked="{Binding Settings.ApiServerEnabled}"
                                 OnContent="{loc:Str General.RestApiEnable}"
                                 OffContent="{loc:Str General.RestApiEnable}"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="{loc:Str General.Port}" Style="{StaticResource LabelStyle}"/>
                <TextBox Text="{Binding Settings.ApiServerPort}"
                         Style="{StaticResource InputTextBoxStyle}"
                         Width="100" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Text="{loc:Str Settings.AutoSaveHint}"
                       Style="{StaticResource HintStyle}" Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
