<UserControl x:Class="TypeWhisper.Windows.Views.Sections.ModelsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="600" Margin="24">
            <TextBlock Text="Transkriptions-Provider" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="Lokale und Cloud-basierte Spracherkennung"
                       Style="{StaticResource HintStyle}" Margin="0,0,0,16"/>

            <!-- Status message -->
            <TextBlock Text="{Binding ModelManager.BusyMessage}"
                       Foreground="{StaticResource AccentBrush}" FontSize="12"
                       Margin="0,0,0,8"
                       Visibility="{Binding ModelManager.IsBusy, Converter={StaticResource BoolToVis}}"/>

            <ItemsControl ItemsSource="{Binding ModelManager.Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProviderViewModel}">
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- Provider Header -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                                               Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>

                                <!-- Capabilities hint -->
                                <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11" Margin="0,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Transkription"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLlmTranslation}" Value="True">
                                                    <Setter Property="Text" Value="Transkription + LLM-Übersetzung"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- API Key hint (only for cloud providers that need configuration) -->
                                <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11" Margin="0,0,0,8"
                                           FontStyle="Italic"
                                           Text="API-Key konfigurieren unter Erweiterungen">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SupportsDownload}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Models List -->
                                <ItemsControl ItemsSource="{Binding Models}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:ModelItemViewModel}">
                                            <Border Padding="8,6" Margin="0,2"
                                                    CornerRadius="4" Cursor="Hand"
                                                    MouseLeftButtonUp="Model_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Background" Value="#1A4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                                            <TextBlock Text=" (Empfohlen)" Foreground="{StaticResource ActiveIndicatorBrush}"
                                                                       FontSize="13"
                                                                       Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                                   Visibility="{Binding SupportsDownload, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding SizeDescription}" Foreground="{StaticResource HintBrush}" FontSize="11"/>
                                                            <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11"
                                                                       Text="{Binding LanguageCount, StringFormat=' · {0} Sprachen'}"/>
                                                            <TextBlock Foreground="{StaticResource HintBrush}" FontSize="11"
                                                                       Visibility="{Binding SupportsTranslation, Converter={StaticResource BoolToVis}}"
                                                                       Text=" · Übersetzung"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource HintBrush}" FontSize="11"/>
                                                    </StackPanel>
                                                    <!-- Active indicator -->
                                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                               FontSize="11" Margin="8,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value=""/>
                                                                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Text" Value="Aktiv"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource ActiveIndicatorBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
