<UserControl x:Class="TypeWhisper.Windows.Views.Sections.AdvancedSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="600" Margin="24">
            <TextBlock Text="{loc:Str Nav.Advanced}" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Memory -->
            <TextBlock Text="Memory" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,24,0,8"/>
            <TextBlock Text="Automatically extracts facts from your transcriptions using an LLM. Memories are injected into prompt context."
                       Style="{StaticResource HintStyle}" Margin="0,0,0,12"/>

            <StackPanel Margin="0,0,0,24">
                <CheckBox Content="Enable Memory" IsChecked="{Binding Settings.MemoryEnabled, Mode=TwoWay, FallbackValue=False}"/>
            </StackPanel>

            <!-- Recording -->
            <TextBlock Text="Recording" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,0,0,8"/>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Auto-unload model" Style="{StaticResource LabelStyle}"/>
                <TextBlock Text="Automatically unloads local models from memory after inactivity. Does not affect cloud engines."
                           Style="{StaticResource HintStyle}" Margin="0,0,0,8"/>
                <ComboBox Width="200" HorizontalAlignment="Left"
                          SelectedValue="{Binding Settings.AutoUnloadMinutes, FallbackValue=0}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Never" Tag="0"/>
                    <ComboBoxItem Content="After 5 minutes" Tag="5"/>
                    <ComboBoxItem Content="After 15 minutes" Tag="15"/>
                    <ComboBoxItem Content="After 30 minutes" Tag="30"/>
                    <ComboBoxItem Content="After 1 hour" Tag="60"/>
                </ComboBox>
            </StackPanel>

            <!-- Spoken Feedback -->
            <StackPanel Margin="0,0,0,16">
                <CheckBox Content="Spoken feedback"
                          IsChecked="{Binding Settings.SpokenFeedbackEnabled, Mode=TwoWay, FallbackValue=False}"/>
                <TextBlock Text="Reads back the transcribed text via speech synthesis after each dictation."
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>

            <!-- History Retention -->
            <TextBlock Text="Data" Style="{StaticResource SectionHeaderStyle}" FontSize="16" Margin="0,8,0,8"/>
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="History retention" Style="{StaticResource LabelStyle}"/>
                <ComboBox Width="200" HorizontalAlignment="Left"
                          SelectedValue="{Binding Settings.HistoryRetentionDays}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="7 days" Tag="7"/>
                    <ComboBoxItem Content="30 days" Tag="30"/>
                    <ComboBoxItem Content="90 days" Tag="90"/>
                    <ComboBoxItem Content="1 year" Tag="365"/>
                    <ComboBoxItem Content="Forever" Tag="9999"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
