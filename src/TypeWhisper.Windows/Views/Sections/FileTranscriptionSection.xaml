<UserControl x:Class="TypeWhisper.Windows.Views.Sections.FileTranscriptionSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,22,28,28" MaxWidth="980">
            <Border AllowDrop="True"
                    Drop="OnDrop"
                    DragOver="OnDragOver"
                    Background="Transparent"
                    BorderBrush="#4B545E"
                    BorderThickness="2"
                    CornerRadius="18"
                    Padding="28">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Str FileTranscription.DragHint}"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Str FileTranscription.Or}"
                               Foreground="{StaticResource HintBrush}"
                               Margin="0,10,0,10"
                               HorizontalAlignment="Center"/>
                    <Button Content="{loc:Str FileTranscription.SelectFile}"
                            Click="OnSelectFile"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="18,8"
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Str FileTranscription.Formats}"
                               Foreground="{StaticResource HintBrush}"
                               FontSize="12"
                               Margin="0,14,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionDividerStyle}"/>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str FileTranscription.Importer}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FileTranscription.StatusText}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           FontSize="15"
                                           Margin="0"/>
                                <Button Grid.Column="1"
                                        Content="{loc:Str FileTranscription.Cancel}"
                                        Command="{Binding FileTranscription.CancelCommand}"
                                        Visibility="{Binding FileTranscription.IsProcessing, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"/>
                            </Grid>
                        </Border>

                        <ProgressBar Grid.Row="0"
                                     IsIndeterminate="{Binding FileTranscription.IsProcessing}"
                                     Height="3"
                                     VerticalAlignment="Bottom"
                                     Visibility="{Binding FileTranscription.IsProcessing, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str FileTranscription.ModelSettings}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str FileTranscription.Engine}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FileTranscription.FileTranscriptionEngineOptions}"
                                          SelectedValue="{Binding FileTranscription.FileTranscriptionEngineSelection}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str FileTranscription.Model}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FileTranscription.FileTranscriptionModelOptions}"
                                          SelectedValue="{Binding FileTranscription.FileTranscriptionModelSelection}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding FileTranscription.CanChooseFileTranscriptionModel}"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str FileTranscription.Queue}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FileTranscription.StatusText}"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           FontSize="15"
                                           Margin="0"/>
                                <Button Grid.Column="1"
                                        Content="{loc:Str FileTranscription.CancelAll}"
                                        Command="{Binding FileTranscription.CancelCommand}"
                                        Visibility="{Binding FileTranscription.IsProcessing, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"/>
                            </Grid>
                        </Border>
                        <Border Height="1" Background="#18FFFFFF"/>
                        <ListBox ItemsSource="{Binding FileTranscription.Items}"
                                 SelectedItem="{Binding FileTranscription.SelectedItem, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource QueueListBoxItemStyle}"
                                 Visibility="{Binding FileTranscription.HasItems, Converter={StaticResource BoolToVis}}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,14,0">
                                                <TextBlock Text="{Binding FileName}"
                                                           Style="{StaticResource SettingsRowLabelStyle}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Style="{StaticResource HintStyle}"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="{loc:Str FileTranscription.Copy}"
                                                        Command="{Binding DataContext.FileTranscription.CopyItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding HasResult}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="{loc:Str FileTranscription.TextExportShort}"
                                                        Command="{Binding DataContext.FileTranscription.ExportItemTextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding HasResult}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="SRT"
                                                        Command="{Binding DataContext.FileTranscription.ExportItemSrtCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanExportSubtitles}"
                                                        ToolTip="{loc:Str FileTranscription.SubtitleUnavailable}"
                                                        ToolTipService.ShowOnDisabled="True"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="WebVTT"
                                                        Command="{Binding DataContext.FileTranscription.ExportItemWebVttCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanExportSubtitles}"
                                                        ToolTip="{loc:Str FileTranscription.SubtitleUnavailable}"
                                                        ToolTipService.ShowOnDisabled="True"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="{loc:Str FileTranscription.Cancel}"
                                                        Command="{Binding DataContext.FileTranscription.CancelItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanCancel}"
                                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                            </StackPanel>

                                            <ProgressBar Grid.Row="1"
                                                         Grid.ColumnSpan="2"
                                                         IsIndeterminate="{Binding IsProcessing}"
                                                         Height="4"
                                                         Margin="0,10,0,0"
                                                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>

                                            <TextBox Grid.Row="2"
                                                     Grid.ColumnSpan="2"
                                                     Text="{Binding ResultText, Mode=OneWay}"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     MinHeight="120"
                                                     Margin="0,10,0,0"
                                                     Style="{StaticResource InputTextBoxStyle}"
                                                     Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str WatchFolder.Title}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Text="{loc:Str WatchFolder.WatchFolder}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                    <TextBlock Text="{Binding FileTranscription.WatchFolderPath, TargetNullValue=''}"
                                               Style="{StaticResource HintStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="{loc:Str WatchFolder.SelectFolder}"
                                        Click="OnSelectWatchFolder"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Text="{loc:Str WatchFolder.OutputFolder}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                    <TextBlock Text="{Binding FileTranscription.WatchFolderOutputPathDisplay}"
                                               Style="{StaticResource HintStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="{loc:Str WatchFolder.Clear}"
                                            Command="{Binding FileTranscription.ClearWatchFolderOutputPathCommand}"
                                            Visibility="{Binding FileTranscription.HasWatchFolderOutputPath, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8"
                                            Margin="0,0,8,0"/>
                                    <Button Content="{loc:Str WatchFolder.SelectFolder}"
                                            Click="OnSelectWatchFolderOutput"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Background="#18FFFFFF"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.OutputFormat}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FileTranscription.WatchFolderOutputFormatOptions}"
                                          SelectedValue="{Binding FileTranscription.WatchFolderOutputFormat}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5" Background="#18FFFFFF"/>

                        <Border Grid.Row="6" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.AutoStart}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 IsChecked="{Binding FileTranscription.WatchFolderAutoStart}"
                                                 OnContent=""
                                                 OffContent=""/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="7" Background="#18FFFFFF"/>

                        <Border Grid.Row="8" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.DeleteSource}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 IsChecked="{Binding FileTranscription.WatchFolderDeleteSource}"
                                                 OnContent=""
                                                 OffContent=""/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="9" Background="#18FFFFFF"/>

                        <Border Grid.Row="10" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,14,0">
                                    <TextBlock Text="{Binding FileTranscription.WatchFolderStatusText}"
                                               Style="{StaticResource SettingsRowLabelStyle}"/>
                                    <TextBlock Text="{loc:Str WatchFolder.Description}"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="{loc:Str WatchFolder.Start}"
                                            Command="{Binding FileTranscription.StartWatchFolderCommand}"
                                            IsEnabled="{Binding FileTranscription.HasWatchFolderPath}"
                                            Visibility="{Binding FileTranscription.IsWatchFolderStopped, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8"
                                            Margin="0,0,8,0"/>
                                    <Button Content="{loc:Str WatchFolder.Stop}"
                                            Command="{Binding FileTranscription.StopWatchFolderCommand}"
                                            Visibility="{Binding FileTranscription.IsWatchFolderRunning, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="14,8"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str WatchFolder.ModelSettings}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.Engine}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FileTranscription.WatchFolderEngineOptions}"
                                          SelectedValue="{Binding FileTranscription.WatchFolderEngineSelection}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#18FFFFFF"/>

                        <Border Grid.Row="2" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.Model}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FileTranscription.WatchFolderModelOptions}"
                                          SelectedValue="{Binding FileTranscription.WatchFolderModelSelection}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding FileTranscription.CanChooseWatchFolderModel}"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Background="#18FFFFFF"/>

                        <Border Grid.Row="4" Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.Language}" Style="{StaticResource SettingsRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding FileTranscription.WatchFolderLanguageOptions}"
                                          SelectedValue="{Binding FileTranscription.WatchFolderLanguage}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Style="{StaticResource SettingsSectionStyle}">
                <TextBlock Text="{loc:Str WatchFolder.History}" Style="{StaticResource SettingsGroupTitleStyle}"/>
                <Border Style="{StaticResource SettingsGroupPanelStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Str WatchFolder.HistoryHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                <Button Grid.Column="1"
                                        Content="{loc:Str WatchFolder.ClearHistory}"
                                        Command="{Binding FileTranscription.ClearWatchFolderHistoryCommand}"
                                        Visibility="{Binding FileTranscription.HasWatchFolderHistory, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="14,8"/>
                            </Grid>
                        </Border>
                        <Border Height="1" Background="#18FFFFFF"/>
                        <ItemsControl ItemsSource="{Binding FileTranscription.WatchFolderHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SettingsRowBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="38"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource SuccessBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="OK"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Success}" Value="False">
                                                                <Setter Property="Text" Value="!"/>
                                                                <Setter Property="Foreground" Value="#F87171"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding FileName}"
                                                           Style="{StaticResource SettingsRowLabelStyle}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding OutputPath}"
                                                           Style="{StaticResource HintStyle}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,5,0,0"/>
                                                <TextBlock Text="{Binding ErrorMessage}"
                                                           Foreground="#F87171"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
