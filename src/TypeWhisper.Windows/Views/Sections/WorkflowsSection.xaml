                                             MinHeight="88"
                                             Style="{StaticResource WorkflowTextAreaStyle}"
                                             Margin="0,0,0,14"
                                             Visibility="{Binding Workflows.IsCustomTemplate, Converter={StaticResource BoolToVis}}"/>

