                                                    Padding="12,6"
                                                    IsEnabled="{Binding Workflows.HasCurrentWebsiteDomain}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE774;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,6,0"/>
                                                    <TextBlock Text="{loc:Str Workflows.DomainUseCurrent}"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Border Style="{StaticResource WorkflowPickerPanelStyle}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0"
                                                            Width="34"
                                                            Height="34"
                                                            CornerRadius="9"
                                                            Background="#14337FD8"
                                                            BorderBrush="#225E9FF2"
                                                            BorderThickness="1"
                                                            Margin="0,0,10,0">
                                                        <TextBlock Text="&#xE774;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="16"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{loc:Str Workflows.DomainPickerTitle}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12.5"/>
                                                        <TextBlock Text="{loc:Str Workflows.DomainPickerHint}"
                                                                   Style="{StaticResource HintStyle}"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="{Binding Workflows.CurrentWebsiteDomain}"
                                                           Foreground="{StaticResource HintBrush}"
                                                           FontSize="10.5"
                                                           Margin="44,0,0,10"
                                                           Visibility="{Binding Workflows.HasCurrentWebsiteDomain, Converter={StaticResource BoolToVis}}"/>

                                                <TextBlock Text="{loc:Str Workflows.DomainPickerEmpty}"
                                                           Style="{StaticResource HintStyle}"
                                                           Margin="2,4,0,0"
                                                           Visibility="{Binding Workflows.HasDomainSuggestions, Converter={StaticResource InverseBoolToVis}}"/>

                                                <ItemsControl ItemsSource="{Binding Workflows.DomainSuggestions}"
                                                              Visibility="{Binding Workflows.HasDomainSuggestions, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource WorkflowPickerRowButtonStyle}"
                                                                    Command="{Binding DataContext.Workflows.AddDomainSuggestionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0"
                                                                            Width="34"
                                                                            Height="34"
                                                                            CornerRadius="9"
                                                                            Background="#14337FD8"
                                                                            BorderBrush="#225E9FF2"
                                                                            BorderThickness="1"
                                                                            Margin="0,0,10,0">
                                                                        <TextBlock Text="&#xE774;"
                                                                                   FontFamily="Segoe MDL2 Assets"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   FontSize="15"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding Domain}"
                                                                                   Foreground="{StaticResource TextBrush}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="12.5"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Detail}"
                                                                                   Foreground="{StaticResource HintBrush}"
                                                                                   FontSize="10.5"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="&#xE710;"
                                                                               FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="15"
                                                                               Foreground="{StaticResource AccentBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="12,0,0,0"/>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding Workflows.IsHotkeyTriggerSelected, Converter={StaticResource BoolToVis}}" Margin="0,0,0,14">
                                        <TextBlock Text="{loc:Str Hotkey.ModifierOnlyHint}" Style="{StaticResource HintStyle}" Margin="0,0,0,8"/>
