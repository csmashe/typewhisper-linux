                                                        <MultiBinding Converter="{StaticResource EqualityToString}">
                                                            <Binding Path="Kind"/>
                                                            <Binding Path="DataContext.Workflows.EditTriggerKind" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
