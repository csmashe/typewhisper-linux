                                                                        </Border>
                                                                        <TextBlock Text="&#xE73E;"
                                                                                   FontFamily="Segoe MDL2 Assets"
                                                                                   FontSize="16"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding Workflows.IsWebsiteTriggerSelected, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl ItemsSource="{Binding Workflows.WebsitePatternChips}">
                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource WorkflowRemovableChipStyle}" Margin="0,0,6,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding}" Foreground="#D6DEE9" FontSize="10.5"/>
                                                            <Button Style="{StaticResource WorkflowChipCloseButtonStyle}"
                                                                    Command="{Binding DataContext.Workflows.RemoveWebsitePatternChipCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="&#xE711;"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="8"
                                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBox x:Name="WebsitePatternInputBox"
                                                     Text="{Binding Workflows.WebsitePatternInput, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource WorkflowInputTextBoxStyle}"
                                                     KeyDown="WebsitePatternInputBox_KeyDown"/>
                                            <Button Grid.Column="1"
                                                    Content="{loc:Str Workflows.Add}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding Workflows.AddWebsitePatternChipCommand}"
                                                    Margin="8,0,0,0"
                                                    Padding="12,6"/>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding Workflows.AddCurrentWebsiteDomainCommand}"
