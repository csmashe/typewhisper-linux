                                                              SelectedValuePath="Value"
                                                              DisplayMemberPath="DisplayName"
                                                              Style="{StaticResource WorkflowComboBoxStyle}"/>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Visibility="{Binding Workflows.SupportsSelectedTranscriptionTranslation, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{loc:Str Workflows.EngineTask}" Style="{StaticResource WorkflowFieldLabelStyle}"/>
                                                <ComboBox ItemsSource="{Binding Workflows.TaskOptions}"
                                                          SelectedValue="{Binding Workflows.EditTask}"
                                                          SelectedValuePath="Value"
                                                          DisplayMemberPath="DisplayName"
                                                          Style="{StaticResource WorkflowComboBoxStyle}"
                                                          Margin="0,0,0,8"/>
                                                <TextBlock Text="{loc:Str Workflows.EngineTaskHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                            </StackPanel>

                                            <TextBlock Text="{loc:Str Workflows.EngineTaskUnavailable}"
                                                       Style="{StaticResource HintStyle}"
                                                       Visibility="{Binding Workflows.SupportsSelectedTranscriptionTranslation, Converter={StaticResource InverseBoolToVis}}"/>
