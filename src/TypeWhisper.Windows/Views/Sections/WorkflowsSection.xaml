<UserControl x:Class="TypeWhisper.Windows.Views.Sections.WorkflowsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:TypeWhisper.Windows.Converters"
             xmlns:controls="clr-namespace:TypeWhisper.Windows.Controls"
             xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility"/>
            <conv:WorkflowTriggerDetailConverter x:Key="WorkflowTriggerDetail"/>
            <conv:WorkflowTemplateNameConverter x:Key="WorkflowTemplateName"/>
            <conv:WorkflowTemplateIconConverter x:Key="WorkflowTemplateIcon"/>
            <conv:WorkflowTriggerIconConverter x:Key="WorkflowTriggerIcon"/>
            <conv:WorkflowEnabledLabelConverter x:Key="WorkflowEnabledLabel"/>
            <conv:WorkflowToggleLabelConverter x:Key="WorkflowToggleLabel"/>
            <conv:EqualityToStringConverter x:Key="EqualityToString"/>

            <Style x:Key="WorkflowIconBubbleStyle" TargetType="Border">
                <Setter Property="Width" Value="38"/>
                <Setter Property="Height" Value="38"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Background" Value="#14337FD8"/>
                <Setter Property="BorderBrush" Value="#335E9FF2"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="WorkflowFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsRowLabelStyle}">
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource HintBrush}"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="WorkflowPanelTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsGroupTitleStyle}">
                <Setter Property="FontSize" Value="14.5"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="WorkflowListRowStyle" TargetType="Border" BasedOn="{StaticResource SettingsCollectionRowStyle}">
                <Setter Property="MinHeight" Value="78"/>
                <Setter Property="Background" Value="#111A25"/>
                <Setter Property="BorderBrush" Value="#1EFFFFFF"/>
                <Setter Property="Padding" Value="14,10"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#142131"/>
                        <Setter Property="BorderBrush" Value="#335E9FF2"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                        <Setter Property="Background" Value="#0E151E"/>
                        <Setter Property="Opacity" Value="0.82"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowSearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SettingsCompactTextBoxStyle}">
                <Setter Property="MinHeight" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Padding" Value="8,0,8,0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="WorkflowInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource SettingsCompactTextBoxStyle}">
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="Padding" Value="8,3,8,3"/>
            </Style>

            <Style x:Key="WorkflowTextAreaStyle" TargetType="TextBox" BasedOn="{StaticResource WorkflowInputTextBoxStyle}">
                <Setter Property="Padding" Value="8,6,8,6"/>
                <Setter Property="VerticalContentAlignment" Value="Top"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="WorkflowComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource SettingsCompactComboBoxStyle}">
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="MinWidth" Value="320"/>
                <Setter Property="MaxWidth" Value="420"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Padding" Value="8,0,8,0"/>
            </Style>

            <Style x:Key="WorkflowRemovableChipStyle" TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                <Setter Property="Padding" Value="7,3"/>
            </Style>

            <Style x:Key="WorkflowChipCloseButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="5,0,0,0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#9FB2C7"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseChrome"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    CornerRadius="7"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseChrome" Property="Background" Value="#25364A"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CloseChrome" Property="Background" Value="#335E9FF2"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WorkflowIconActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Background" Value="#233248"/>
                <Setter Property="Foreground" Value="#D7E4F3"/>
                <Setter Property="BorderBrush" Value="#2C415C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ActionChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ActionChrome" Property="Background" Value="#17395F"/>
                                    <Setter TargetName="ActionChrome" Property="BorderBrush" Value="#5E9FF2"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ActionChrome" Property="Background" Value="#0F2B4D"/>
                                    <Setter TargetName="ActionChrome" Property="BorderBrush" Value="#7AB4FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WorkflowStatusToggleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#2A3038"/>
                <Setter Property="BorderBrush" Value="#53606E"/>
                <Setter Property="Foreground" Value="#C9D2DE"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,3"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="StatusChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                    <Setter Property="Background" Value="#123C2B"/>
                                    <Setter Property="BorderBrush" Value="#2DBE73"/>
                                    <Setter Property="Foreground" Value="#9AF5C4"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                                    <Setter Property="Background" Value="#3A2430"/>
                                    <Setter Property="BorderBrush" Value="#B75A6C"/>
                                    <Setter Property="Foreground" Value="#FFD0D8"/>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="#1A4D38"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="StatusChrome" Property="BorderBrush" Value="#52E69B"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="False"/>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="#4A2533"/>
                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="StatusChrome" Property="BorderBrush" Value="#FF7A90"/>
                                </MultiDataTrigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="StatusChrome" Property="Background" Value="#0E2B20"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WorkflowChoiceButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#18212D"/>
                <Setter Property="BorderBrush" Value="#26364A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ChoiceChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChoiceChrome" Property="Background" Value="#1D2A3A"/>
                                    <Setter TargetName="ChoiceChrome" Property="BorderBrush" Value="#36506E"/>
                                </Trigger>
                                <Trigger Property="Tag" Value="True">
                                    <Setter TargetName="ChoiceChrome" Property="Background" Value="#14337FD8"/>
                                    <Setter TargetName="ChoiceChrome" Property="BorderBrush" Value="#5E9FF2"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ChoiceChrome" Property="Background" Value="#12306CBE"/>
                                    <Setter TargetName="ChoiceChrome" Property="BorderBrush" Value="#7AB4FF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.58"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WorkflowPickerPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#111B27"/>
                <Setter Property="BorderBrush" Value="#26364A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,14"/>
            </Style>

            <Style x:Key="WorkflowPickerRowButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#18212D"/>
                <Setter Property="BorderBrush" Value="#26364A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RowChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RowChrome" Property="Background" Value="#1D2A3A"/>
                                    <Setter TargetName="RowChrome" Property="BorderBrush" Value="#36506E"/>
                                </Trigger>
                                <Trigger Property="Tag" Value="True">
                                    <Setter TargetName="RowChrome" Property="Background" Value="#14337FD8"/>
                                    <Setter TargetName="RowChrome" Property="BorderBrush" Value="#5E9FF2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SettingsSummaryBarStyle}"
                Visibility="{Binding Workflows.IsEditorOpen, Converter={StaticResource InverseBoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Grid.RowSpan="2"
                        Width="48"
                        Height="48"
                        CornerRadius="14"
                        Background="#16337FD8"
                        BorderBrush="#335E9FF2"
                        BorderThickness="1"
                        Margin="0,0,16,0"
                        VerticalAlignment="Top">
                    <TextBlock Text="&#xE8F1;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="24"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                    <TextBlock Text="{loc:Str Workflows.Title}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Workflows.WorkflowSummary}" Style="{StaticResource PageSubtitleStyle}" Margin="0,0,0,4"/>
                    <TextBlock Text="{loc:Str Workflows.Subtitle}" Style="{StaticResource HintStyle}" Margin="0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding Workflows.StartCreateCommand}"
                        Padding="14,7"
                        FontSize="12"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,7,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{loc:Str Workflows.New}"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Margin="0,16,0,0"
                            MaxWidth="520"
                            HorizontalAlignment="Left">
                    <TextBlock Text="{loc:Str Workflows.DefaultAiProvider}"
                               Style="{StaticResource HintStyle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Workflows.AvailableProviders}"
                              SelectedItem="{Binding Workflows.SelectedDefaultProvider}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource WorkflowComboBoxStyle}"/>
                    <TextBlock Text="{loc:Str Workflows.DefaultAiProviderHint}"
                               Style="{StaticResource HintStyle}"
                               FontSize="11"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,16,0,0"
              Visibility="{Binding Workflows.IsEditorOpen, Converter={StaticResource InverseBoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBox Text="{Binding Workflows.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource WorkflowSearchTextBoxStyle}"/>
                        </Grid>

                        <Border Grid.Row="1" Style="{StaticResource SettingsGroupPanelStyle}">
                            <Grid>
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            MaxWidth="260"
                                            Margin="28"
                                            Visibility="{Binding Workflows.HasFilteredWorkflows, Converter={StaticResource InverseBoolToVis}}">
                                    <TextBlock Text="&#xE8F1;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="34"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,12"/>
                                    <TextBlock Text="{loc:Str Workflows.EmptyTitle}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{loc:Str Workflows.EmptySubtitle}"
                                               Style="{StaticResource PageSubtitleStyle}"
                                               TextAlignment="Center"
                                               Margin="0,0,0,18"/>
                                    <Button Content="{loc:Str Workflows.CreateFirst}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding Workflows.StartCreateCommand}"
                                            Padding="14,7"
                                            HorizontalAlignment="Center"/>
                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding Workflows.HasFilteredWorkflows, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl ItemsSource="{Binding Workflows.FilteredWorkflows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource WorkflowListRowStyle}"
                                                        Margin="0,0,0,2"
                                                        PreviewMouseLeftButtonDown="WorkflowRow_PreviewMouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Style="{StaticResource WorkflowIconBubbleStyle}"
                                                                Margin="0,0,12,0"
                                                                VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Template, Converter={StaticResource WorkflowTemplateIcon}}"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="18"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" Margin="0,0,18,0" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="14.5"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <Button Style="{StaticResource WorkflowStatusToggleButtonStyle}"
                                                                        Command="{Binding DataContext.Workflows.ToggleWorkflowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip="{Binding IsEnabled, Converter={StaticResource WorkflowToggleLabel}}"
                                                                        Tag="{Binding IsEnabled}"
                                                                        Margin="10,0,0,0">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#x25CF;"
                                                                                   FontSize="8"
                                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,0,5,0"/>
                                                                        <TextBlock Text="{Binding IsEnabled, Converter={StaticResource WorkflowEnabledLabel}}"
                                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                                   FontSize="10.5"
                                                                                   FontWeight="SemiBold"/>
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>

                                                            <TextBlock Text="{Binding Converter={StaticResource WorkflowTriggerDetail}}"
                                                                       Foreground="{StaticResource HintBrush}"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,0,0,8"/>

                                                            <WrapPanel>
                                                                <Border Background="#16337FD8"
                                                                        BorderBrush="#335E9FF2"
                                                                        BorderThickness="1"
                                                                        CornerRadius="9"
                                                                        Padding="8,4"
                                                                        Margin="0,0,6,6">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Template, Converter={StaticResource WorkflowTemplateIcon}}"
                                                                                   FontFamily="Segoe MDL2 Assets"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   Margin="0,0,5,0"/>
                                                                        <TextBlock Text="{Binding Template, Converter={StaticResource WorkflowTemplateName}}" Foreground="#D6DEE9" FontSize="10"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </WrapPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Style="{StaticResource WorkflowIconActionButtonStyle}"
                                                                    Command="{Binding DataContext.Workflows.StartEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="{loc:Str Workflows.Edit}">
                                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
        </Grid>

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Background="{StaticResource BackgroundBrush}"
                Margin="-24,0,-24,-24"
                Visibility="{Binding Workflows.IsEditorOpen, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="#111B27"
                                            BorderBrush="#22364D"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="14"
                                            Margin="24,0,24,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding Workflows.CancelEditorCommand}"
                                                    Padding="10,7"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72B;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="12"
                                                               Margin="0,0,7,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{loc:Str Workflows.Back}"/>
                                                </StackPanel>
                                            </Button>
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource WorkflowIconBubbleStyle}"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Workflows.SelectedTemplateIconGlyph}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="18"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Workflows.EditorTitle}" Style="{StaticResource WorkflowPanelTitleStyle}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding Workflows.SelectedTemplateDescription}" Style="{StaticResource HintStyle}" Margin="0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Style="{StaticResource BadgeStyle}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,12,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Workflows.SelectedTriggerIconGlyph}"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="10"
                                                                   Foreground="#D6DEE9"
                                                                   Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Workflows.EditTriggerKind}" Foreground="#D6DEE9" FontSize="10"/>
                                                    </StackPanel>
                                                </Border>
                                                <CheckBox Content="{loc:Str Workflows.Enabled}"
                                                          IsChecked="{Binding Workflows.EditIsEnabled}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0"/>
                                                <Button Content="{loc:Str Workflows.Delete}"
                                                        Style="{StaticResource LinkButtonStyle}"
                                                        Command="{Binding Workflows.DeleteWorkflowCommand}"
                                                        CommandParameter="{Binding Workflows.SelectedWorkflow}"
                                                        Visibility="{Binding Workflows.IsCreatingNew, Converter={StaticResource InverseBoolToVis}}"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Center"/>
                                                <Button Content="{loc:Str Workflows.Cancel}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding Workflows.CancelEditorCommand}"
                                                        Padding="12,7"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="{loc:Str Workflows.Save}"
