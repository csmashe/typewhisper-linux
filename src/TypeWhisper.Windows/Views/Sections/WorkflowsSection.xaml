                                    <TextBlock Text="{loc:Str Workflows.Output}" Style="{StaticResource WorkflowPanelTitleStyle}"/>
                                    <TextBlock Text="{loc:Str Workflows.OutputFormat}" Style="{StaticResource WorkflowFieldLabelStyle}"/>
                                    <TextBox Text="{Binding Workflows.EditOutputFormat, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WorkflowInputTextBoxStyle}" Margin="0,0,0,12"/>
                                    <CheckBox Content="{loc:Str Workflows.AutoEnter}" IsChecked="{Binding Workflows.EditAutoEnter}" Margin="0,0,0,12"/>
                                    <TextBlock Text="{loc:Str Workflows.ActionPlugin}" Style="{StaticResource WorkflowFieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding Workflows.ActionPluginOptions}"
                                              SelectedValue="{Binding Workflows.EditTargetActionPluginId}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource WorkflowComboBoxStyle}"
                                              Margin="0,0,0,14"/>

                                    <Border Background="#111B27"
                                            BorderBrush="#22364D"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="14"
                                            Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="&#xE8FB;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="18"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{loc:Str Workflows.Review}" Style="{StaticResource WorkflowFieldLabelStyle}"/>
                                                <TextBlock Text="{Binding Workflows.ReviewText}" Style="{StaticResource PageSubtitleStyle}" TextWrapping="Wrap" Margin="0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
