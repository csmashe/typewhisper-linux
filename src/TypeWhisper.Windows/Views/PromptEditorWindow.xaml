<Window x:Class="TypeWhisper.Windows.Views.PromptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        xmlns:vm="clr-namespace:TypeWhisper.Windows.ViewModels"
        Title="{Binding EditorTitle}"
        Width="620" Height="680"
        MinWidth="560" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource WizardShellStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="{Binding EditorTitle}" Style="{StaticResource SettingsGroupTitleStyle}" FontSize="22" Margin="0,0,0,4"/>
                <TextBlock Text="{loc:Str Prompts.EditorSubtitle}" Style="{StaticResource PageSubtitleStyle}" Margin="0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{loc:Str Prompts.Icon}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,0,0,8"/>
                    <Border Style="{StaticResource SettingsGroupPanelStyle}">
                        <ItemsControl ItemsSource="{x:Static vm:PromptsViewModel.IconOptions}" Margin="14,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            FontSize="18"
                                            Padding="8,4"
                                            Margin="0,0,6,6"
                                            Click="IconPick_Click"
                                            Style="{StaticResource SecondaryButtonStyle}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock Text="{loc:Str Prompts.PromptGroup}" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,4,0,8"/>
                    <Border Style="{StaticResource SettingsGroupPanelStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str Prompts.NameLabel}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SettingsCompactTextBoxStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Height="1" Background="#16FFFFFF"/>

                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Str Prompts.SystemPrompt}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding EditSystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource WizardTrialTextBoxStyle}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             VerticalContentAlignment="Top"
                                             MinHeight="170"/>
                                </StackPanel>
                            </Border>

                            <Border Height="1" Background="#16FFFFFF"/>

                            <Border Style="{StaticResource SettingsRowBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,14,0">
                                        <TextBlock Text="{loc:Str Prompts.ProviderOverride}" Style="{StaticResource SettingsRowLabelStyle}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{loc:Str Prompts.ProviderHint}" Style="{StaticResource HintStyle}" Margin="0"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableProviders}"
                                              SelectedValue="{Binding EditProviderOverride}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              Style="{StaticResource SettingsAlignedComboBoxStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="{loc:Str Prompts.Cancel}"
                        IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2"
                        Content="{loc:Str Prompts.Save}"
                        IsDefault="True"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,8"
                        Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
