<ui:FluentWindow x:Class="TypeWhisper.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        Title="{loc:Str Settings.Title}"
        MinWidth="800"
        MinHeight="500"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- WPF-UI Title Bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="{loc:Str Settings.Title}"
                     ShowMaximize="False"/>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#18FFFFFF">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,8,0,0">

                    <!-- Core -->
                    <Button Content="{loc:Str Nav.Home}"
                            Command="{Binding NavigateCommand}" CommandParameter="Home">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Home">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.General}"
                            Command="{Binding NavigateCommand}" CommandParameter="General">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="General">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Recording}"
                            Command="{Binding NavigateCommand}" CommandParameter="Recording">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Recording">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Models}"
                            Command="{Binding NavigateCommand}" CommandParameter="Models">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Models">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Background="#15FFFFFF" Margin="16,12"/>

                    <Button Content="{loc:Str Nav.Recorder}"
                            Command="{Binding NavigateCommand}" CommandParameter="Recorder">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Recorder">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.History}"
                            Command="{Binding NavigateCommand}" CommandParameter="History">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="History">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Dictionary}"
                            Command="{Binding NavigateCommand}" CommandParameter="Dictionary">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Dictionary">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Snippets}"
                            Command="{Binding NavigateCommand}" CommandParameter="Snippets">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Snippets">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Profiles}"
                            Command="{Binding NavigateCommand}" CommandParameter="Profiles">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Profiles">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Prompts}"
                            Command="{Binding NavigateCommand}" CommandParameter="Prompts">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Prompts">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Background="#15FFFFFF" Margin="16,12"/>

                    <Button Content="{loc:Str Nav.Plugins}"
                            Command="{Binding NavigateCommand}" CommandParameter="Plugins">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Plugins">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.Advanced}"
                            Command="{Binding NavigateCommand}" CommandParameter="Advanced">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="Advanced">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Background="#15FFFFFF" Margin="16,12"/>

                    <Button Content="{loc:Str Nav.License}"
                            Command="{Binding NavigateCommand}" CommandParameter="License">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="License">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="{loc:Str Nav.About}"
                            Command="{Binding NavigateCommand}" CommandParameter="About">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSectionName}" Value="About">
                                        <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Sidebar/Content separator -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Right"
                    Width="1"
                    Background="#15FFFFFF"/>

            <!-- Content Area -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentSection}"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
