<Window x:Class="TypeWhisper.Windows.Views.FileTranscriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:TypeWhisper.Windows.Services.Localization"
        Title="{loc:Str FileTranscription.Title}"
        Width="860" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="640" MinHeight="460"
        AllowDrop="True"
        Drop="OnDrop" DragOver="OnDragOver">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UnifiedSettingsStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Border BorderThickness="2"
                    BorderBrush="#4B545E"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,8"
                    Background="Transparent"
                    AllowDrop="True">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Str FileTranscription.DragHint}"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               Foreground="{StaticResource LabelBrush}"/>
                    <TextBlock Text="{loc:Str FileTranscription.Or}" HorizontalAlignment="Center" Foreground="{StaticResource HintBrush}" Margin="0,4"/>
                    <Button Content="{loc:Str FileTranscription.SelectFile}" Click="OnSelectFile"
                            HorizontalAlignment="Center" Padding="16,6" Margin="0,4"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{StaticResource HintBrush}"/>
                <Button Grid.Column="1"
                        Content="{loc:Str FileTranscription.CancelAll}"
                        Command="{Binding CancelCommand}"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"/>
            </Grid>
        </StackPanel>

        <ListBox ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemContainerStyle="{StaticResource QueueListBoxItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource SettingsCollectionRowStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding FileName}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding StatusText}"
                                           Style="{StaticResource HintStyle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="{loc:Str FileTranscription.Copy}"
                                        Command="{Binding DataContext.CopyItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding HasResult}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,6,0"/>
                                <Button Content="{loc:Str FileTranscription.TextExportShort}"
                                        Command="{Binding DataContext.ExportItemTextCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding HasResult}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,6,0"/>
                                <Button Content="SRT"
                                        Command="{Binding DataContext.ExportItemSrtCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanExportSubtitles}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,6,0"/>
                                <Button Content="WebVTT"
                                        Command="{Binding DataContext.ExportItemWebVttCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanExportSubtitles}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,6,0"/>
                                <Button Content="{loc:Str FileTranscription.Cancel}"
                                        Command="{Binding DataContext.CancelItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding CanCancel}"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </StackPanel>

                            <ProgressBar Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         IsIndeterminate="{Binding IsProcessing}"
                                         Height="4"
                                         Margin="0,10,0,0"
                                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>

                            <TextBox Grid.Row="2"
                                     Grid.ColumnSpan="2"
                                     Text="{Binding ResultText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="120"
                                     Margin="0,10,0,0"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
