<UserControl x:Class="TypeWhisper.Plugin.Obsidian.ObsidianSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,4">
        <!-- Vault Selection -->
        <TextBlock Text="Obsidian Vault" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Select a detected vault or enter a path manually."
                   Foreground="Gray" FontSize="12" Margin="0,0,0,8" />

        <ComboBox x:Name="VaultComboBox"
                  DisplayMemberPath="Name"
                  SelectionChanged="OnVaultSelectionChanged"
                  Margin="0,0,0,8" />

        <TextBlock Text="Vault Path" FontSize="12" Foreground="Gray" Margin="0,0,0,4" />
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="VaultPathTextBox"
                     Grid.Column="0"
                     LostFocus="OnVaultPathChanged"
                     Padding="4,4" />
            <Button Grid.Column="1" Content="Browse..."
                    Click="OnBrowseVault"
                    Padding="8,4" Margin="8,0,0,0" />
        </Grid>

        <!-- Subfolder -->
        <TextBlock Text="Subfolder" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Folder within the vault where notes are saved."
                   Foreground="Gray" FontSize="12" Margin="0,0,0,8" />
        <TextBox x:Name="SubfolderTextBox"
                 LostFocus="OnSubfolderChanged"
                 Padding="4,4" Margin="0,0,0,16" />

        <!-- Daily Note Mode -->
        <CheckBox x:Name="DailyNoteCheckBox"
                  Content="Daily note mode (append to a single note per day)"
                  Checked="OnDailyNoteModeChanged"
                  Unchecked="OnDailyNoteModeChanged"
                  Margin="0,0,0,16" />

        <!-- Filename Template -->
        <TextBlock Text="Filename Template" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="Available placeholders: {{date}}, {{time}}, {{app}}"
                   Foreground="Gray" FontSize="12" Margin="0,0,0,8" />
        <TextBox x:Name="FilenameTemplateTextBox"
                 LostFocus="OnFilenameTemplateChanged"
                 Padding="4,4" Margin="0,0,0,8" />

        <!-- Status -->
        <TextBlock x:Name="StatusText" Foreground="Gray" FontStyle="Italic" Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
